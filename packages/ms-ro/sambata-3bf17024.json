  "data": {
    "headword": "sâmbătă",
    "definition": "A șasea zi a săptămânii, după vineri și înainte de duminică.",
    "pronunciation": "/ˈsɨmbətə/",
    "etymology": {
      "text": "Cuvântul românesc „sâmbătă” provine din latină, din 'sabbatum', care la rândul său provine din ebraicul 'Shabbat', ziua de odihnă.",
      "source": "Dicționare etimologice, studii lingvistice"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Sâmbătă mergem la cinema."
    },
    {
      "text": "Sâmbăta este ziua mea preferată."
