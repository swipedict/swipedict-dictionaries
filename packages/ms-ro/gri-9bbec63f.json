  "data": {
    "headword": "gri",
    "definition": "O culoare între negru și alb, adesea percepută ca neutră sau tristă.",
    "pronunciation": "/ɡri/",
    "etymology": {
      "text": "Adjectivul românesc „gri” provine din latină, de la 'griseus', care desemna o culoare cenușie.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
