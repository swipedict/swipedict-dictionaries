  "data": {
    "headword": "nu știu",
    "definition": "Expresie folosită pentru a indica lipsa de cunoștințe sau necunoașterea unui lucru.",
    "pronunciation": "/nu ˈʃti.u/",
    "etymology": {
      "text": "Expresia românească „nu știu” este formată din negația „nu” și verbul „știu” (eu știu), care provine din latină, din verbul 'sapere', ce înseamnă 'a ști'.",
      "source": "Dicționare etimologice românești"
    }
  },
  "examples": [
    {
      "text": "Nu știu unde este el."
    },
    {
      "text": "Nu știu cum funcționează asta."
    },
    {
      "text": "Ai idee despre matematică? – Nu, nu știu."
    },
    {
      "text": "M-a întrebat, dar eu nu știam."
    }
