  "data": {
    "headword": "a împărți",
    "definition": "a descompune ceva în două sau mai multe părți și a le oferi altora",
    "pronunciation": "/a ɨmpərˈtsi/",
    "etymology": {
      "text": "Provine din latinescul „partire“, care înseamnă „a împărți“, folosit pentru a descrie divizarea unui cuvânt în litere.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
