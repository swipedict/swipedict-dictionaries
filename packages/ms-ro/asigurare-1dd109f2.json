  "data": {
    "headword": "asigurare",
    "definition": "Un contract sau o instituție care oferă protecție împotriva riscurilor financiare, plătind o despăgubire în caz de daună.",
    "pronunciation": "/a.si.guˈra.re/",
    "etymology": {
      "text": "Cuvântul românesc „asigurare” provine din verbul latin 'assicurare', preluat prin italiană 'assicurare', care înseamnă „a face sigur”.",
      "source": "Dicționare etimologice, studii lingvistice"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Asigurarea plătește dauna după accident."
    },
    {
      "text": "Am încheiat o asigurare de răspundere civilă."
    },
    {
      "text": "Asigurarea protejează împotriva pierderilor financiare."
    },
    {
      "text": "Mulți oameni încheie o asigurare de viață."
    }
