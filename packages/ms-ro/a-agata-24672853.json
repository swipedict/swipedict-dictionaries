  "data": {
    "headword": "a agăța",
    "definition": "A fixa ceva pe un cârlig sau cui astfel încât să atârne, de exemplu o poză.",
    "pronunciation": "/a aɡəˈtsa/",
    "etymology": {
      "text": "Verbul românesc „a agăța” provine din slavona 'agati', care înseamnă 'a atârna' sau 'a agăța'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu agăț poza pe perete."
    },
    {
      "text": "Poți, te rog, să agăți poza?"
    },
    {
      "text": "Ea agață haina de cârlig."
    },
    {
      "text": "Trebuie să agățăm poza corect."
    }
