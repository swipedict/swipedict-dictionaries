  "data": {
    "headword": "roată",
    "definition": "O piesă rotundă, de obicei mobilă, folosită la vehicule precum biciclete sau mașini pentru deplasare.",
    "pronunciation": "/roˈa.tə/",
    "etymology": {
      "text": "Cuvântul românesc „roată” provine din latină, din termenul 'rota', care înseamnă 'roată' și are forme similare în multe limbi romanice.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Bicicleta are două roți."
    },
    {
      "text": "Mașina are nevoie de patru roți pentru a merge."
    },
    {
      "text": "Roata se învârte repede."
    },
    {
      "text": "Roata de rezervă este în portbagaj."
