  "data": {
    "headword": "a întinde rufele",
    "definition": "A agăța hainele ude pentru a se usca pe o sârmă sau un suport pentru rufe.",
    "pronunciation": "/a ɨnˈtinde ruˈfe.le/",
    "etymology": {
      "text": "Verbul românesc „a întinde“ provine din latină „intendere“, care înseamnă „a întinde“ sau „a întinde“, iar „rufe“ vine din latină „ropa“ pentru haine.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Întind rufele după spălat."
    },
    {
      "text": "Poți să întinzi rufele, te rog?"
    },
    {
      "text": "Rufele se usucă repede dacă le întinzi."
    },
