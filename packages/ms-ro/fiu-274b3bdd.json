    "etymology": {
      "text": "Cuvântul românesc „fiu” provine din latină, de la 'filius', care înseamnă 'fiul' și este păstrat similar în multe limbi romanice.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
