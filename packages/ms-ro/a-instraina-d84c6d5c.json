  "data": {
    "headword": "a înstrăina",
    "definition": "a îndepărta pe cineva de ceva sau a lua sentimentul de legătură",
    "pronunciation": "/a ɨnstrəˈina/",
    "etymology": {
      "text": "Verbul românesc „a înstrăina“ provine din latină, din „alienare“, care înseamnă „a face străin“ și exprimă sentimentul de înstrăinare.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Mă înstrăinez de societate."
    },
    {
      "text": "Te înstrăinezi de prietenii tăi?"
    },
    {
      "text": "El se înstrăinează de cultură."
    },
    {
      "text": "Ne înstrăinăm de rădăcinile noastre."
    },
    {
      "text": "Vă înstrăinați de tradițiile voastre?"
    },
    {
      "text": "Ei se înstrăinează de cultura lor."
    },
    {
      "text": "M-am înstrăinat de vechiul credință."
    },
    {
      "text": "El se înstrăina în gândurile lui."
    },
    {
      "text": "Mă voi înstrăina de negativitate."
    },
    {
      "text": "M-aș înstrăina dacă nu aș avea pe nimeni."
    },
    {
      "text": "Nu te înstrăina de familia ta!"
    }
