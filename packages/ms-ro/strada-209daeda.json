  "data": {
    "headword": "stradă",
    "definition": "Un drum amenajat pentru circulația vehiculelor și a pietonilor într-o localitate.",
    "pronunciation": "/straˈdə/",
    "etymology": {
      "text": "Cuvântul românesc „stradă” provine direct din latină 'strata (via)', care înseamnă 'drum pavat' sau 'cale consolidată', având aceeași rădăcină ca și cuvântul german.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Strada este foarte aglomerată astăzi."
    },
    {
      "text": "Locuim într-o stradă liniștită."
    },
    {
      "text": "Copiii se joacă pe stradă."
    },
    {
      "text": "Strada duce la gară."
    },
    {
      "text": "În oraș sunt multe străzi."
