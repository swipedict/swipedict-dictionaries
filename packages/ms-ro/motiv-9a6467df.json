    "etymology": {
      "text": "Cuvântul românesc „motiv” provine din francezul 'motif', care la rândul său vine din latină 'motivus', însemnând 'care mișcă' sau 'care determină'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
