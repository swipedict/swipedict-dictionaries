  "data": {
    "headword": "zvon",
    "definition": "O informație neconfirmată care se răspândește unter oameni.",
    "pronunciation": "/zvon/",
    "etymology": {
      "text": "Cuvântul românesc „zvon” provine din slavă, legat de vechiul slav 'zvъnŭ', care înseamnă 'sunet' sau 'clopot', folosit metaforic pentru o veste răspândită.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Zvonul s-a răspândit rapid în oraș."
    },
    {
      "text": "Am auzit doar un zvon, nu o informație confirmată."
    },
    {
      "text": "Zvonurile pot face adesea rău."
    }
  ],
