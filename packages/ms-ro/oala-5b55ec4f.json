  "data": {
    "headword": "oală",
    "definition": "Un vas rotund, de obicei din metal sau ceramică, folosit pentru gătit sau depozitarea alimentelor.",
    "pronunciation": "/o̯aˈlə/",
    "etymology": {
      "text": "Cuvântul românesc „oală” provine din latinescul 'olla', care desemna un vas rotund de lut folosit în Antichitate pentru gătit.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Oala este pe aragaz."
    },
    {
      "text": "Gătesc supă în oala mare."
    },
    {
      "text": "Oala are un capac."
    },
    {
      "text": "Te rog să folosești oala pentru legume."
