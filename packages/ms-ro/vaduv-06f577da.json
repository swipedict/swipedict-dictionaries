  "data": {
    "headword": "văduv",
    "definition": "Persoană care și-a pierdut soțul sau soția prin deces.",
    "pronunciation": "/vəˈduv/",
    "etymology": {
      "text": "Cuvântul românesc „văduv” provine din latinescul 'viduus', care înseamnă 'liber de soț/soție' sau 'văduv', evoluând din latina clasică.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Ea este văduvă de un an."
    },
    {
      "text": "Bărbatul văduv trăiește singur."
    },
    {
      "text": "După moartea soțului ei, a rămas văduvă."
    },
    {
      "text": "Mulți văduvi au nevoie de sprijin."
    }
  ],
