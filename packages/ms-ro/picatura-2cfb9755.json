  "data": {
    "headword": "picătură",
    "definition": "O cantitate mică de lichid, rotundă, care cade încet de pe ceva.",
    "pronunciation": "/piˈkə.tu.rə/",
    "etymology": {
      "text": "Cuvântul românesc „picătură” provine din latină, din 'pictura' care inițial însemna 'pictură', dar în română a evoluat semantic spre 'picătură mică', probabil influențat de verbul 'a picura' (a picura).",
      "source": "Dicționare etimologice, studii lingvistice"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "O picătură de apă a căzut pe podea."
    },
    {
      "text": "Picăturile ploii băteau în geam."
    },
    {
      "text": "Te rog, dă-mi câteva picături de medicament."
    },
    {
      "text": "Picăturile lacrimilor străluceau în lumină."
    }
  ],
