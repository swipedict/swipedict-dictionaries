  "data": {
    "headword": "apartament",
    "definition": "O unitate locativă delimitată, de obicei parte a unei clădiri, folosită pentru locuit.",
    "pronunciation": "/apaɾtaˈment/",
    "etymology": {
      "text": "Cuvântul românesc „apartament” provine din franceza 'appartement', care la rândul său derivă din italiană 'appartamento', de la verbul 'appartare' ce înseamnă 'a separa'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Caut un apartament în oraș."
    },
    {
      "text": "Apartamentul are trei camere și un balcon."
    },
    {
      "text": "Locuim într-un apartament frumos."
