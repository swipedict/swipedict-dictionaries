  "data": {
    "headword": "a întâlni",
    "definition": "a vedea și a vorbi cu cineva întâmplător sau intenționat",
    "pronunciation": "/a ɨn.tɨlˈni/",
    "etymology": {
      "text": "Verbul românesc „a întâlni“ derivă din latină „intertalia“ („printre altele“), evoluând în sensul de a se întâlni cu cineva.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu întâlnesc pe prietenul meu."
    },
    {
      "text": "Întâlnești familia?"
    },
    {
      "text": "El întâlnește colegii lui."
    },
    {
      "text": "Noi ne întâlnim mâine."
    },
    {
      "text": "Întâlniți vecinii?"
    },
    {
      "text": "Ei se întâlnesc regulat."
    },
    {
      "text": "Am întâlnit-o."
    },
    {
      "text": "Ea întâlnea multe persoane noi."
    },
    {
      "text": "Te voi întâlni mâine."
    },
    {
      "text": "Aș vrea să te întâlnesc."
    },
    {
      "text": "Întâlnește-ne la timp!"
    }
