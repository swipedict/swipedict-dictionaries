  "data": {
    "headword": "soți",
    "definition": "Un cuplu căsătorit, adică soț și soție împreună.",
    "pronunciation": "/ˈso.t͡sʲ/",
    "etymology": {
      "text": "Cuvântul românesc „soți” provine din latinul 'socius', care înseamnă 'însoțitor' sau 'partener', fiind folosit în mod special pentru partenerii de căsătorie.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Soții sărbătoresc astăzi aniversarea căsătoriei."
    },
    {
      "text": "Soții locuiesc într-o casă mică."
    },
    {
      "text": "Soții au doi copii."
    },
    {
      "text": "Soții sunt căsătoriți de zece ani."
    }
