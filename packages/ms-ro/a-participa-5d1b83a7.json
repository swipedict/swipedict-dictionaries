  "data": {
    "headword": "a participa",
    "definition": "A lua parte activ la un eveniment, o activitate sau o întâlnire.",
    "pronunciation": "/a partiˈt͡ʃipa/",
    "etymology": {
      "text": "Verbul românesc „a participa“ provine din latină, din „participare“, compus din „pars“ (parte) și „capere“ (a lua), însemnând a lua parte la ceva.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu particip la conferință."
    },
    {
      "text": "Ieri am participat la ședință."
    },
    {
      "text": "Ea participa des la concursuri."
    },
    {
