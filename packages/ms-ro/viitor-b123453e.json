  "data": {
    "headword": "viitor",
    "definition": "Timpul care urmează să vină; ceea ce este în viitor.",
    "pronunciation": "/viˈitor/",
    "etymology": {
      "text": "Cuvântul românesc „viitor” provine din latinul 'vitare' care înseamnă 'a evita', dar în română a căpătat sensul de 'viitor', 'ce urmează'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Viitorul este incert."
    },
    {
      "text": "Planificăm pentru viitor."
    },
    {
      "text": "În viitor vreau să călătoresc."
    },
    {
      "text": "Viitorul aparține celor curajoși."
    }
