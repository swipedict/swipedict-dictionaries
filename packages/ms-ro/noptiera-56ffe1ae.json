  "data": {
    "headword": "noptieră",
    "definition": "O piesă mică de mobilier plasată lângă pat, folosită pentru a pune diverse obiecte.",
    "pronunciation": "/nopˈtjerə/",
    "etymology": {
      "text": "Cuvântul românesc „noptieră” provine din latinescul 'noctuaria', derivat din 'noctuarius', care înseamnă „aparținând nopții”, desemnând o piesă de mobilier folosită pe timpul nopții.",
      "source": "Dicționar Etymologic Român"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Noptiera este așezată lângă pat."
    },
    {
      "text": "Pun cartea pe noptieră."
    },
    {
      "text": "Pe noptieră este o lampă."
    },
    {
      "text": "Sertarul din noptieră este plin."
    }
