  "data": {
    "headword": "daună",
    "definition": "Un prejudiciu sau o pagubă care afectează o persoană sau un obiect.",
    "pronunciation": "/ˈda.unə/",
    "etymology": {
      "text": "Cuvântul românesc „daună” provine din latină, din termenul 'damnum', care înseamnă 'pagubă' sau 'pierdere' și are forme similare în multe limbi romanice.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Dauna la mașină este considerabilă."
    },
    {
      "text": "Asigurarea acoperă dauna."
    },
    {
      "text": "A suferit o daună mare în urma accidentului."
    },
    {
      "text": "Trebuie reparată dauna cât mai repede posibil."
    }
