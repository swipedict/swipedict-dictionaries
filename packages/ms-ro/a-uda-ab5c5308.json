  "data": {
    "headword": "a uda",
    "definition": "A furniza apă, în special pentru plante sau pentru a umezi pământul.",
    "pronunciation": "/a ˈuda/",
    "etymology": {
      "text": "Verbul românesc „a uda” provine din verbul latin 'udare', care înseamnă 'a umezi' sau 'a face umed', având rădăcina latină 'ud-'.",
      "source": "Dicționare etimologice, Analiză lingvistică"
    }
  },
  "examples": [
    {
      "text": "Udez florile în fiecare dimineață."
    },
    {
      "text": "Fermierul udă câmpul după plantare."
    },
    {
      "text": "Te rog să nu uzi prea mult, altfel rădăcinile putrezesc."
    },
    {
      "text": "Pământul trebuie udat regulat."
    }
  ],
