  "data": {
    "headword": "ierburi",
    "definition": "Plante sau părți de plante folosite pentru aromă, gust sau proprietăți medicinale.",
    "pronunciation": "/jerˈburi/",
    "etymology": {
      "text": "Cuvântul românesc „ierburi” provine direct din cuvântul latin 'herba', care înseamnă 'plantă' sau 'iarbă' și a preluat înțelesul de plante aromatice sau medicinale.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Folosesc ierburi proaspete pentru gătit."
    },
    {
      "text": "Ierburi precum busuiocul și pătrunjelul sunt foarte populare."
    },
    {
      "text": "Unele ierburi au efecte vindecătoare."
    },
    {
      "text": "Ierburile cresc în grădină."
    }
