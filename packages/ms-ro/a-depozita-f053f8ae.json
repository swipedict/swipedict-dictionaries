  "data": {
    "headword": "a depozita",
    "definition": "a păstra sau a stoca ceva, adesea într-o cameră sau recipient specific",
    "pronunciation": "/de.po.ziˈta/",
    "etymology": {
      "text": "Verbul românesc „a depozita“ provine din latină, de la „deponere“, care înseamnă „a pune jos, a depozita“, fiind legat de substantivul „depozit“, locul unde se păstrează obiecte.",
      "source": "Etymological Dictionaries, Wiktionary"
    }
  },
  "examples": [
    {
      "text": "Îmi depozitez mobila în pivniță."
    },
    {
      "text": "Am depozitat produsele."
    },
    {
      "text": "Voi depozita proviziile."
    },
    {
      "text": "Aș depozita cutiile dacă aș avea timp."
    },
    {
      "text": "Depozitând cărțile, le și sortezi."
    }
  ],
