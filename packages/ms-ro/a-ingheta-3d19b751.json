  "data": {
    "headword": "a îngheța",
    "definition": "a avea o senzație de frig; a simți o temperatură rece",
    "pronunciation": "/a ɨnˈɡe.t͡sa/",
    "etymology": {
      "text": "Verbul românesc „a îngheța“ derivă din latină, din „infrigescere“, însemnând „a îngheța“ sau „a deveni rece“, descriind procesul de solidificare la frig.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu îngheț afară."
    },
    {
      "text": "Te rog să nu îngheți!"
    },
    {
      "text": "El îngheață, pentru că este frig."
    },
    {
      "text": "Noi înghețăm iarna."
    },
    {
      "text": "Înghețați voi la această frig?"
    },
    {
      "text": "Am înghețat când am fost afară."
    }
