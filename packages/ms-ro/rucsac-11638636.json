  "data": {
    "headword": "rucsac",
    "definition": "Un sac purtat pe spate, prevăzut cu două bretele, folosit pentru a transporta obiecte.",
    "pronunciation": "/rukˈsak/",
    "etymology": {
      "text": "Cuvântul românesc „rucsac” este împrumutat din germanul „Rucksack”, format în secolul al XIX-lea din 'Ruck' (spate) și 'Sack' (sac).",
      "source": "Dicționare etimologice, studii lingvistice"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Îmi împachetez rucsacul pentru drumeție."
    },
    {
      "text": "Rucsacul este greu pentru că am multe cărți cu mine."
    },
    {
      "text": "Ea poartă rucsacul pe spate."
    },
    {
      "text": "Un rucsac bun are bretele căptușite."
    }
