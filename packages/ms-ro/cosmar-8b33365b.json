  "data": {
    "headword": "coșmar",
    "definition": "Un vis neplăcut, adesea înfricoșător, care provoacă teamă sau neliniște la trezire.",
    "pronunciation": "/koʃˈmar/",
    "etymology": {
      "text": "Cuvântul românesc „coșmar” provine din slavonă, din termenul 'košmarŭ', care înseamnă 'vis rău' sau 'coșmar'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Am avut un coșmar urât noaptea trecută."
    },
    {
      "text": "Coșmarul l-a trezit transpirat."
    },
    {
      "text": "Mulți copii au uneori coșmaruri."
    },
    {
      "text": "După coșmar, nu a mai putut să adoarmă."
    }
