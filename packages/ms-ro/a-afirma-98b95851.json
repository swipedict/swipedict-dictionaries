    "etymology": {
      "text": "Românescul „a afirma“ derivă din latină, de la „affirmare“ (a confirma), format din „ad-“ (către) și „firmare“ (a întări).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
