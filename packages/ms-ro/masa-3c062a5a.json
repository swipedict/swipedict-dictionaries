  "data": {
    "headword": "masă",
    "definition": "O piesă de mobilier cu o suprafață plată, folosită pentru a mânca, a lucra sau a pune obiecte.",
    "pronunciation": "/ˈmasə/",
    "etymology": {
      "text": "Cuvântul românesc „masă” provine din latină, de la „mensa”, care însemna 'masă' sau 'tablă', și a ajuns să desemneze și 'masă' ca moment de luat masa.",
      "source": "Dicționare etimologice, studii lingvistice"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Masa este din lemn."
    },
    {
      "text": "Stăm la masă și mâncăm."
    },
    {
      "text": "Masa are patru picioare."
    },
    {
      "text": "Te rog, pune masa."
    }
  ],
