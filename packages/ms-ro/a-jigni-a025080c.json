  "data": {
    "headword": "a jigni",
    "definition": "a trata pe cineva prost sau a spune ceva care îl rănește",
    "pronunciation": "/a dʒiɡˈni/",
    "etymology": {
      "text": "Verbul românesc „a jigni“ provine din slavă, de la „jigniti“, care înseamnă a jigni sau a răni emoțional.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Nu jignesc pe nimeni intenționat."
    },
    {
      "text": "Îl jignești cu cuvintele tale?"
    },
    {
      "text": "Ea jignește adesea colegii ei."
    },
    {
      "text": "Nu jignim pe nimeni în discuție."
    },
    {
      "text": "Îi jigniți pe oaspeți?"
    },
    {
      "text": "Ei jignesc adesea sentimentele altora."
    },
    {
      "text": "L-am jignit ieri."
    },
    {
      "text": "El o jignia adesea la școală."
    },
    {
      "text": "Nu o să jignesc pe nimeni."
    },
    {
      "text": "Nu l-aș jigni dacă aș putea."
    },
    {
      "text": "Nu-l jigni!"
    }
