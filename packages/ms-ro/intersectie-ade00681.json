  "data": {
    "headword": "intersecție",
    "definition": "Locul unde două sau mai multe străzi sau drumuri se întâlnesc sau se taie.",
    "pronunciation": "/in.ter.sekˈtsi.e/",
    "etymology": {
      "text": "Cuvântul românesc „intersecție” provine din verbul latin 'intersecāre', care înseamnă 'a tăia prin' sau 'a se intersecta', format din prefixul 'inter-' (între) și 'secāre' (a tăia).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Intersecția este foarte aglomerată."
    },
    {
      "text": "La intersecție trebuie să faci stânga."
    },
    {
      "text": "La intersecție este un semafor."
    },
    {
      "text": "Pietonii traversează intersecția cu grijă."
