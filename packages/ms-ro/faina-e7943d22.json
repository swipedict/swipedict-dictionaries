  "data": {
    "headword": "făină",
    "definition": "Pulbere fină obținută prin măcinarea cerealelor, folosită la copt și gătit.",
    "pronunciation": "/fəˈinə/",
    "etymology": {
      "text": "Cuvântul românesc „făină” derivă din latină 'farina', care inițial însemna 'făină' sau 'cereale măcinate', fiind o componentă esențială a alimentației romane.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Am nevoie de făină pentru a coace pâine."
    },
    {
      "text": "Făina este făcută din grâu."
    },
    {
      "text": "Pentru prăjitură ai nevoie de făină, zahăr și ouă."
    },
    {
      "text": "Făina este depozitată în cămară."
    }
