  "data": {
    "headword": "liniștit",
    "definition": "Descrie o stare fără zgomot, agitație sau tulburare; calm, pașnic.",
    "pronunciation": "/liˈniʃtit/",
    "etymology": {
      "text": "Adjectivul românesc „linistit” derivă din verbul latin 'lenire', care înseamnă 'a calma' sau 'a liniști', evoluând către adjectivul pentru 'liniștit' sau 'calm'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Copilul este foarte liniștit astăzi."
    },
    {
      "text": "Te rog, fii liniștit, trebuie să mă concentrez."
    },
    {
      "text": "Lacul este liniștit și pașnic în vale."
    },
    {
      "text": "Noaptea este de obicei liniștită."
    }
