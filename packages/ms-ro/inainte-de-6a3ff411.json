  "data": {
    "headword": "înainte de",
    "definition": "O prepoziție care exprimă poziția spațială sau temporală anterioară unui obiect sau eveniment.",
    "pronunciation": "/ɨnˈaj̯te de/",
    "etymology": {
      "text": "Cuvântul românesc „înainte” provine din expresia latină 'in ante', care înseamnă 'în fața' sau 'înainte'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Aștept în fața casei."
    },
    {
      "text": "Înainte de masă îmi spăl mâinile."
    },
    {
      "text": "Concertul începe înainte de miezul nopții."
    }
