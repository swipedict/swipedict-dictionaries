  "data": {
    "headword": "maro",
    "definition": "O culoare care amintește de lemn, pământ sau ciocolată.",
    "pronunciation": "/ˈmaro/",
    "etymology": {
      "text": "Cuvântul românesc „maro” provine din franceza 'marron', care inițial însemna 'castan' și este folosit pentru culoarea maro.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
