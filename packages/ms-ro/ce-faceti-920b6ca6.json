  "data": {
    "headword": "Ce faceți?",
    "definition": "O formulă de salut formală folosită pentru a întreba politicos despre starea de bine a unei persoane.",
    "pronunciation": "/tʃe faˈt͡ʃeʦ/",
    "etymology": {
      "text": "Expresia românească „Ce faceți?“ provine de la pronumele interogativ latin 'quid' (dezvoltat în 'ce') și verbul 'a face', derivat din latină 'facere', care înseamnă 'a face'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
