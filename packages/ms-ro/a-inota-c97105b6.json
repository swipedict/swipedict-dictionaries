  "data": {
    "headword": "a înota",
    "definition": "A se deplasa în apă prin mișcarea brațelor și picioarelor pentru a nu se scufunda.",
    "pronunciation": "/a iˈnota/",
    "etymology": {
      "text": "Verbul românesc „a înota” provine din verbul latin 'innotare', compus din 'in-' (înăuntru) și 'notare' (a înota, a pluti), însemnând 'a înota în'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu înot în fiecare dimineață în lac."
    },
    {
      "text": "Știi să înoți bine?"
    },
    {
      "text": "Am înotat ieri la piscină."
    },
    {
      "text": "El înoată repede și sigur."
    },
    {
      "text": "Nu înota prea departe!"
    }
