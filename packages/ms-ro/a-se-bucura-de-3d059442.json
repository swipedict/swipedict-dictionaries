    "etymology": {
      "text": "Expresia românească „a se bucura de“ derivă din latinescul „bucuria“ și înseamnă a experimenta plăcere sau satisfacție față de ceva.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
