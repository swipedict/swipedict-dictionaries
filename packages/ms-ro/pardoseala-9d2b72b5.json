  "data": {
    "headword": "pardoseală",
    "definition": "Suprafața interioară a unei încăperi pe care se calcă; podeaua unei clădiri.",
    "pronunciation": "/par.doˈse.a.lə/",
    "etymology": {
      "text": "Cuvântul românesc „pardoseală” derivă din latinescul 'particella', care înseamnă 'parte mică', evoluând în română prin 'pardos' pentru 'sol' sau 'podea'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Pardoseala este curată și strălucește."
    },
    {
      "text": "Am pus o pardoseală nouă în sufragerie."
    },
    {
      "text": "Pardoseala se simte rece."
    },
    {
      "text": "Te rog să mături pardoseala regulat."
