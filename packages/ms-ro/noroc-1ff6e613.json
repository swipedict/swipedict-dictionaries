  "data": {
    "headword": "Noroc!",
    "definition": "O expresie folosită la ciocnitul paharelor pentru a ura sănătate și bunăstare.",
    "pronunciation": "/noˈrok/",
    "etymology": {
      "text": "Cuvântul românesc „noroc” provine din slavona 'norok', însemnând 'noroc' sau 'soartă'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Spunem „Noroc!” înainte să bem."
    },
    {
      "text": "Noroc! Pentru sănătatea ta!"
    },
    {
      "text": "La petrecere toți au strigat „Noroc!” și au ciocnit paharele."
    },
    {
      "text": "El a ridicat paharul și a spus „Noroc!”"
    }
  ],
  "relatedWords": [
    {
