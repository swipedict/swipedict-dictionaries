    "headword": "întuneric",
    "definition": "starea în care nu există sau există foarte puțină lumină",
    "pronunciation": "/ɨntuˈne.riːk/",
    "etymology": {
      "text": "Cuvântul românesc „întuneric“ provine din slavă și înseamnă „lipsa luminii“. Este folosit frecvent în literatură și filozofie.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
