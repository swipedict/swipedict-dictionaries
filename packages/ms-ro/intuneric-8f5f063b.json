    },
    {
      "text": "În întuneric, auzi cei mai buni sunete."
    },
    {
      "text": "Întunericul poate fi înfricoșător."
    },
    {
      "text": "Întunericul nopții este liniștitor."
    },
    {
      "text": "Întunericul aduce secretele la lumină."
    },
    {
      "text": "Întunericul adesea provoacă frică."
