  "data": {
    "headword": "brânză",
    "definition": "Un aliment obținut prin coagularea și maturarea laptelui.",
    "pronunciation": "/ˈbrɨn.zə/",
    "etymology": {
      "text": "Cuvântul românesc „brânză” provine probabil din slavul 'brynza', care desemna un anumit tip de brânză proaspătă.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Îmi place să mănânc brânză la micul dejun."
    },
    {
      "text": "Brânza proaspătă are un gust blând și cremos."
    },
    {
      "text": "Brânza se face din lapte."
    },
    {
      "text": "În România există multe feluri diferite de brânză."
    }
