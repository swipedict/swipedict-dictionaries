  "data": {
    "headword": "a părăsi",
    "definition": "a lăsa un loc sau o persoană în urmă",
    "pronunciation": "/a pəˈrə.si/",
    "etymology": {
      "text": "Verbul român „a părăsi“ provine din latină, din „parare“, însemnând „a trece peste, a părăsi“. Este folosit frecvent pentru a exprima părăsirea fizică și emoțională.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
