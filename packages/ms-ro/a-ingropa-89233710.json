  "data": {
    "headword": "a îngropa",
    "definition": "a pune la odihnă pe cineva care a decedat într-un mormânt",
    "pronunciation": "/ɨŋˈɡro.pa/",
    "etymology": {
      "text": "Verbul românesc „a îngropa“ provine de la substantivul „groapă“ (groapă), înrudit cu slavicul „grob“ (mormânt), desemnând acțiunea de a îngropa.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu îngrop bunicul meu."
    },
    {
      "text": "Îngropi pe cineva din familie?"
    },
    {
      "text": "El îngroapă pisica lui."
    },
    {
      "text": "Noi îngropăm morții din comunitate."
    },
    {
      "text": "Îngropați morții împreună?"
    },
    {
      "text": "Ei îngroapă urna."
    },
    {
      "text": "Am îngropat prietenul meu."
    },
    {
      "text": "El îngropa mama lui acum doi ani."
    },
    {
      "text": "Voi îngropa pe el."
    },
    {
      "text": "Îngropă animalele în grădină!"
