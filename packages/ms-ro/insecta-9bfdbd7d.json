  "data": {
    "headword": "insectă",
    "definition": "Un animal mic fără coloană vertebrală, cu șase picioare, adesea cu aripi.",
    "pronunciation": "/inˈsek.tə/",
    "etymology": {
      "text": "Cuvântul românesc „insectă” provine tot din latină, din 'insecta', pluralul de la 'insectum', cu aceeași semnificație.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "O albină este o insectă."
    },
    {
      "text": "Insectele au adesea șase picioare."
    },
    {
      "text": "Fluturele este o insectă frumoasă."
    },
    {
      "text": "Insectele trăiesc în multe medii diferite."
