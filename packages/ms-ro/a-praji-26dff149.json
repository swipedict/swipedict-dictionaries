  "data": {
    "headword": "a prăji",
    "definition": "A găti alimente în ulei sau grăsime fierbinte până devin crocante și aurii.",
    "pronunciation": "/a prəˈʒi/",
    "etymology": {
      "text": "Provine din slavă veche „pragiti“ care înseamnă „a prăji“ sau „a frige“.",
      "source": "DEX, Wiktionary"
    }
  },
  "examples": [
    {
      "text": "Prăjesc cartofii până devin aurii."
    },
    {
      "text": "Nu trebuie să încălzești uleiul prea tare când prăjești."
    },
    {
      "text": "Mâncărurile prăjite sunt adesea foarte crocante."
    },
    {
      "text": "Poți, te rog, să prăjești ceapa?"
    }
