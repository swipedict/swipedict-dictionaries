  "data": {
    "headword": "buruiană",
    "definition": "Plantă care crește într-un loc nedorit, în special în grădini sau câmpuri.",
    "pronunciation": "/bu.ru.iˈa.nə/",
    "etymology": {
      "text": "Cuvântul românesc „buruiană” provine din latină, de la 'burra', care însemna inițial 'puf' sau 'bucăți de lână', evoluând spre sensul de plantă nedorită.",
      "source": "Dicționare etimologice, Analize lingvistice"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "În grădină cresc multe buruieni."
    },
    {
      "text": "Trebuie să smulgem buruienile ca florile să crească mai bine."
    },
    {
      "text": "Buruienile pot reduce recolta de pe câmp."
    },
    {
      "text": "Buruiana se răspândește rapid."
    }
  ],
  "relatedWords": [
    {
      "text": "câmp"
    },
    {
      "text": "grădină"
    },
    {
      "text": "plantă"
    },
    {
      "text": "a smulge buruienile"
    }
  ]
