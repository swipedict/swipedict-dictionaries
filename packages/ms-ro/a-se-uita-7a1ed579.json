  "data": {
    "headword": "a se uita",
    "definition": "A privi ceva pentru o perioadă scurtă sau cu curiozitate, pentru a vedea ce se întâmplă.",
    "pronunciation": "/a se uˈita/",
    "etymology": {
      "text": "Verbul reflexiv românesc „a se uita” derivă din verbul latin 'vidēre', care înseamnă 'a vedea', și s-a dezvoltat prin forma reflexivă pentru a însemna 'a privi' sau 'a se uita în jur'.",
      "source": "Dicționare etimologice, Analiză lingvistică"
    }
  },
  "examples": [
    {
      "text": "Mă uit pe fereastră."
    },
    {
      "text": "Uită-te, acolo este o pasăre!"
    },
    {
      "text": "El se uită curios în cameră."
    },
    {
      "text": "Ne uităm la un film."
    },
    {
      "text": "Nu te uita așa!"
    }
  ],
