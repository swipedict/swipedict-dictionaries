  "data": {
    "headword": "grădiniță",
    "definition": "O instituție pentru îngrijirea și educarea copiilor înainte de începerea școlii.",
    "pronunciation": "/grə.diˈni.t͡sə/",
    "etymology": {
      "text": "Cuvântul românesc „grădiniță” este o formă diminutivă a cuvântului „grădină”, care provine din latină prin influențe slave și desemnează un loc protejat și îngrijit.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Grădinița începe la ora 8 dimineața."
    },
    {
      "text": "Copilul meu merge la grădiniță din acest an."
    },
    {
      "text": "La grădiniță copiii învață prin joacă."
    },
    {
      "text": "Grădinița oferă și prânz."
    }
