  "data": {
    "headword": "măsură",
    "definition": "O acțiune planificată sau un pas luat pentru a atinge un anumit scop.",
    "pronunciation": "/məˈsu.rə/",
    "etymology": {
      "text": "Cuvântul românesc „măsură” provine din latină 'mensura', care înseamnă 'măsură' sau 'măsurare'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Guvernul a luat măsuri noi împotriva pandemiei."
    },
    {
      "text": "Trebuie să luăm măsuri imediat."
    },
    {
      "text": "Această măsură are scopul de a îmbunătăți siguranța."
    }
