  "data": {
    "headword": "a suna",
    "definition": "A emite un sunet clar și repetitiv, cum face clopoțelul unei biciclete.",
    "pronunciation": "/a suˈna/",
    "etymology": {
      "text": "Verbul românesc provine din latină, din „sonare“, care înseamnă „a suna“ sau „a face un sunet“, și descrie semnalizarea unui apel.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Clopoțelul bicicletei sună când apăs maneta."
    },
    {
      "text": "Te rog să suni înainte să deschizi ușa."
    },
    {
      "text": "Telefonul sună tare în birou."
    },
    {
      "text": "El sună la ușa casei."
    }
