  "data": {
    "headword": "rațiune",
    "definition": "Capacitatea omului de a gândi logic și de a acționa în mod deliberat.",
    "pronunciation": "/raˈt͡si.u.ne/",
    "etymology": {
      "text": "Cuvântul românesc „rațiune” provine din latină, din 'ratio, rationis', care înseamnă 'calcul', 'rațiune' sau 'gândire', având forme similare în multe limbi romanice.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Rațiunea cere să acționăm cu prudență."
    },
    {
      "text": "A acționat din pură rațiune."
    },
    {
      "text": "Rațiunea și sentimentul trebuie să fie în echilibru."
    },
    {
      "text": "Rațiunea a învins asupra emoțiilor."
