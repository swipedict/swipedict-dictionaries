    "headword": "a frâna",
    "definition": "A reduce viteza unui vehicul sau a-l opri.",
    "pronunciation": "/a ˈfrɨ.nə/",
    "etymology": {
      "text": "Verbul românesc „a frâna” provine din slavonul 'frana', care înseamnă 'a frâna'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu frânez când văd o intersecție."
    },
    {
      "text": "Mașina frânează brusc."
    },
    {
      "text": "Te rog să frânezi cu grijă pe gheață."
    },
    {
      "text": "A frânat pentru a evita un accident."
