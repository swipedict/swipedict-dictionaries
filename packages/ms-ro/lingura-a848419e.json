  "data": {
    "headword": "lingură",
    "definition": "Un obiect de tacâm cu o parte adâncită, rotundă sau ovală, folosit pentru a lua lichide sau alimente.",
    "pronunciation": "/linˈɡurə/",
    "etymology": {
      "text": "Cuvântul românesc „lingură” provine din latină 'lingula', diminutiv de la 'lingua' (limbă), deoarece forma lingurii amintește de o limbă mică.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Lingura este lângă farfurie."
    },
    {
      "text": "Mănânc supă cu o lingură."
    },
    {
      "text": "Lingura este din argint."
    },
    {
      "text": "Te rog, dă-mi o lingură."
    }
