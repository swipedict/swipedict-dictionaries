  "data": {
    "headword": "ciao",
    "definition": "Formă informală de salut sau rămas bun, împrumutată din italiană.",
    "pronunciation": "/ˈtʃa.o/",
    "etymology": {
      "text": "Cuvântul românesc „ciao” a fost împrumutat direct din italiană și este folosit informal ca salut sau la revedere.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Ciao! Pe mâine!"
    },
    {
      "text": "A spus „ciao” și a plecat."
    },
    {
      "text": "Folosim „ciao” ca salut relaxat între prieteni."
    },
    {
      "text": "„Ciao” este cunoscut ca salut în multe limbi."
    }
