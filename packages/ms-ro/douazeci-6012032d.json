  "data": {
    "headword": "douăzeci",
    "definition": "Numărul 20, care urmează după nouăsprezece și înainte de douăzeci și unu.",
    "pronunciation": "/doˈwə.t͡seʧ/",
    "etymology": {
      "text": "Cuvântul românesc „douăzeci” este compus din 'două' (doi) și o formă veche 'zeci' (zeci), unde 'zeci' provine din latină 'decem' (zece).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
