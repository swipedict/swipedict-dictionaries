  "data": {
    "headword": "a se ciocni",
    "definition": "A se întâlni brusc și cu forță, de obicei cu un impact fizic sau un accident.",
    "pronunciation": "/a se tʃokˈni/",
    "etymology": {
      "text": "Verbul românesc „a se ciocni“ derivă din substantivul „cioc“ care înseamnă „cioc“ sau „vârf“, evoluând metaforic spre sensul de „a se lovi“ sau „a se ciocni“.",
      "source": "Dicționare etimologice, Analize lingvistice"
    }
  },
  "examples": [
    {
      "text": "Mașinile se ciocnesc la intersecție."
    },
    {
      "text": "Ieri două biciclete s-au ciocnit."
    },
    {
      "text": "Pe vremuri, navele se ciocneau des."
    },
    {
      "text": "Mâine trenurile nu se vor ciocni."
    },
    {
      "text": "Ai grijă să nu vă ciocniți!"
