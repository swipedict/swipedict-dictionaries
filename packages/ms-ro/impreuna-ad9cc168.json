  "data": {
    "headword": "împreună",
    "definition": "Adverb care exprimă acțiunea de a fi sau a face ceva în comun, unitate sau simultaneitate.",
    "pronunciation": "/ɨm.preˈu.nə/",
    "etymology": {
      "text": "Cuvântul românesc „împreună” este o compunere din prepoziția 'în' și adverbul 'preună', derivat din latină 'prō' (pentru, înainte), având sensul de 'împreună', 'în comun'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Lucrăm împreună la acest proiect."
    },
    {
      "text": "Au mers împreună la cinema."
    },
    {
      "text": "Să mâncăm împreună."
    },
    {
      "text": "Copiii se joacă împreună în grădină."
    }
