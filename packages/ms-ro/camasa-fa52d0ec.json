  "data": {
    "headword": "cămașă",
    "definition": "Un articol de îmbrăcăminte care acoperă partea superioară a corpului, de obicei cu nasturi în față și guler.",
    "pronunciation": "/kəˈmɨʃə/",
    "etymology": {
      "text": "Cuvântul românesc „cămașă” provine din latină, din 'camisia', care desemna o cămașă simplă sau un tricou, preluat din gallo-romanică.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Cămașa este din bumbac."
    },
    {
      "text": "El poartă o cămașă albă la serviciu."
    },
    {
      "text": "Cămașa are mâneci lungi."
    },
    {
      "text": "Mi-am călcat cămașa."
