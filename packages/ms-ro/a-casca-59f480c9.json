  "data": {
    "headword": "a căsca",
    "definition": "A deschide gura larg, adesea ca semn de oboseală sau plictiseală.",
    "pronunciation": "/a kəˈska/",
    "etymology": {
      "text": "Verbul românesc „a căsca“ este o formă onomatopeică care imită sunetul și mișcarea deschiderii gurii.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Căsc la fel de obosit."
    },
    {
      "text": "El căsca des în timpul orei."
    },
    {
      "text": "Te rog, nu căsca când vorbești!"
    },
    {
      "text": "Bebelușul căsca și adoarme."
    }
