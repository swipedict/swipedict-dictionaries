  "data": {
    "headword": "angajat",
    "definition": "Persoană care acceptă un loc de muncă și primește salariu.",
    "pronunciation": "/anɡaˈd͡ʒat/",
    "etymology": {
      "text": "Cuvântul românesc „angajat” provine din franceza 'engagé', participiul verbului 'engager', care înseamnă 'a angaja'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Angajatul muncește din greu."
    },
    {
      "text": "Angajatul primește salariul la sfârșitul lunii."
    },
    {
      "text": "Mulți angajați sunt mulțumiți de locul lor de muncă."
    },
    {
      "text": "Angajatul a semnat contractul."
