  "data": {
    "headword": "farfurie",
    "definition": "Vas plat, rotund sau oval, folosit pentru servirea mâncării.",
    "pronunciation": "/farˈfu.ri.e/",
    "etymology": {
      "text": "Cuvântul românesc „farfurie” derivă din latinescul 'farfuria', care însemna 'oală mică' sau 'bol' și a fost extins pentru a desemna vase plate.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Farfuria este plină cu mâncare."
    },
    {
      "text": "Te rog, pune farfuria pe masă."
    },
    {
      "text": "Am folosit o farfurie curată."
    },
    {
      "text": "Farfuria a căzut pe podea și s-a spart."
    }
