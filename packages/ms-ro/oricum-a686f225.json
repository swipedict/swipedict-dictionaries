  "data": {
    "headword": "oricum",
    "definition": "Drückt aus, dass etwas auf jeden Fall oder jedenfalls so ist, unabhängig von anderen Umständen.",
    "pronunciation": "/oˈrikum/",
    "etymology": {
      "text": "Cuvântul românesc „oricum” este compus din 'ori' (sau) și 'cum' (cum), însemnând 'oricum', 'în orice caz'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Oricum vin la petrecere."
    },
    {
      "text": "Oricum este o idee bună."
    },
    {
      "text": "Va ploua, dar oricum merg la plimbare."
    },
    {
      "text": "Oricum ai dreptate."
    }
