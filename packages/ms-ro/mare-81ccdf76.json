  "data": {
    "headword": "mare",
    "definition": "Întindere mare de apă sărată care acoperă o parte semnificativă a suprafeței Pământului.",
    "pronunciation": "/ˈmare/",
    "etymology": {
      "text": "Adjectivul românesc „mare” provine direct din cuvântul latin 'magnus', care înseamnă 'mare'. În timp, 'magnus' a evoluat în 'mare' în limba română, păstrând sensul original.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Marea este foarte liniștită astăzi."
    },
    {
      "text": "Mergem la mare vara."
    },
