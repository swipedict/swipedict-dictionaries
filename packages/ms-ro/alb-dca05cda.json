  "data": {
    "headword": "alb",
    "definition": "Culoarea care reflectă toate lungimile de undă vizibile ale luminii și este percepută ca luminoasă.",
    "pronunciation": "/alb/",
    "etymology": {
      "text": "Adjectivul românesc „alb” provine din cuvântul latin 'albus', care înseamnă 'alb' sau 'luminos' și are o istorie îndelungată în limbile romanice.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Cămașa este albă și curată."
    },
