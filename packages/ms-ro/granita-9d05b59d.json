    "etymology": {
      "text": "Cuvântul românesc „graniță” provine din latină, din termenul 'granica', preluat în limbile romanice ca denumire pentru linia de frontieră.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
