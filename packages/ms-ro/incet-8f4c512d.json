  "data": {
    "headword": "încet",
    "definition": "Care descrie o viteză mică sau un ritm lent.",
    "pronunciation": "/ɨnˈt͡ʃet/",
    "etymology": {
      "text": "Adjectivul românesc „încet” provine din cuvântul latin 'incitus', care inițial însemna 'rapid', dar în română a căpătat sensul opus, 'încet'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Mașina merge încet."
    },
    {
      "text": "Te rog, vorbește încet."
    },
    {
      "text": "El lucrează încet, dar cu grijă."
    },
    {
      "text": "Ceasul ticăie încet."
    }
