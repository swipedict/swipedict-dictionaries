    "etymology": {
      "text": "Verbul românesc „a protesta” provine direct din latină, din verbul 'protestari', care înseamnă 'a mărturisi public' sau 'a protesta'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
