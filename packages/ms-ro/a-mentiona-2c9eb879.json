  "data": {
    "headword": "a menționa",
    "definition": "A spune scurt și pe scurt ceva, a face o referire.",
    "pronunciation": "/a men.t͡siˈo.na/",
    "etymology": {
      "text": "Verbul românesc „a menționa” provine din franceză, din verbul 'mentionner', care la rândul său derivă din latinescul 'mentio' însemnând 'mențiune' sau 'amintire'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Menționez pe scurt subiectul."
    },
    {
      "text": "El nu a menționat greșeala."
    },
    {
      "text": "Ea menționa des planurile sale."
    },
    {
      "text": "Voi menționa asta mai târziu."
    },
    {
      "text": "Te rog, nu menționa asta!"
