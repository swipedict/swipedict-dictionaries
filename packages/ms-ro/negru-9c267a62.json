  "data": {
    "headword": "negru",
    "definition": "Culoarea care exprimă absența totală a luminii sau o nuanță foarte închisă.",
    "pronunciation": "/ˈneɡru/",
    "etymology": {
      "text": "Adjectivul românesc „negru” provine din cuvântul latin 'niger', care înseamnă 'negru' și are forme similare în multe limbi romanice.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Câinele negru aleargă repede."
    },
    {
      "text": "Ea poartă o rochie neagră la petrecere."
    },
    {
      "text": "Noaptea este neagră și liniștită."
    },
    {
      "text": "Cafea neagră fără zahăr."
    }
