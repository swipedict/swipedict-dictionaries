    "etymology": {
      "text": "Verbul românesc „a depăși” provine din latină, din 'depassare', care înseamnă 'a depăși', iar 'cont' provine din italiană 'conto', împrumutat din latină.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
