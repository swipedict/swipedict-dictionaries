  "data": {
    "headword": "marți",
    "definition": "A doua zi a săptămânii, numită după zeul roman al războiului Mars.",
    "pronunciation": "/ˈmart͡sʲ/",
    "etymology": {
      "text": "Cuvântul românesc „marți” provine din latinul 'Martis dies', care înseamnă 'ziua lui Marte', zeul roman al războiului.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Marți este a doua zi a săptămânii."
    },
    {
      "text": "Marți am o programare."
    },
