  "data": {
    "headword": "șosetă",
    "definition": "Un articol de îmbrăcăminte care acoperă piciorul, de obicei fabricat din material textil sau lână.",
    "pronunciation": "/ʃoˈsetə/",
    "etymology": {
      "text": "Cuvântul românesc „șosetă” provine din latinul 'soccus', similar cu cuvântul german, și desemnează o încălțăminte ușoară pentru picior.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Astăzi port șosete groase."
    },
    {
      "text": "Șoseta este din bumbac."
    },
    {
      "text": "Are o gaură în șoseta lui."
    },
    {
      "text": "Te rog să-ți dai jos șosetele înainte să mergi la culcare."
    }
