  "data": {
    "headword": "pe",
    "definition": "Prepoziție care indică poziția deasupra sau contactul cu o suprafață, precum și sensuri temporale sau abstracte legate de poziție.",
    "pronunciation": "/pe/",
    "etymology": {
      "text": "Cuvântul românesc „pe” derivă din prepoziția latină 'per', care în evoluție a devenit o prepoziție generală de poziție, exprimând contactul sau poziția pe o suprafață.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Cartea este pe masă."
    },
    {
      "text": "Ne întâlnim pe piață."
    },
    {
      "text": "Tabloul atârnă pe perete."
    },
    {
      "text": "În orice caz, vin mâine."
    },
    {
      "text": "El lucrează pe țară."
