  "data": {
    "headword": "Rămâne între noi",
    "definition": "O expresie care înseamnă că ceva rămâne confidențial și nu se va împărtăși altora.",
    "pronunciation": "/rəˈmɨne ˈɨntre ˈnoj/",
    "etymology": {
      "text": "Cuvântul românesc „rămâne“ provine din latină 'remanere', care înseamnă 'a rămâne', iar 'între noi' înseamnă 'între noi'.",
      "source": "Phraseological Studies"
    }
  },
  "examples": [
    {
      "text": "Rămâne între noi, promis!"
    },
    {
      "text": "Nu spune nimănui, rămâne între noi."
    },
    {
      "text": "Această informație rămâne între noi."
    },
    {
      "text": "Ai încredere în mine, rămâne între noi."
    }
