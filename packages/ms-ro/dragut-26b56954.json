  "data": {
    "headword": "drăguț",
    "definition": "Descrie o persoană care este plăcută, simpatică sau atrăgătoare.",
    "pronunciation": "/drəˈɡut/",
    "etymology": {
      "text": "Adjectivul românesc „drăguț” provine din cuvântul slav 'dragŭ', care înseamnă 'drag' sau 'scump', și a evoluat în română pentru a desemna ceva plăcut sau frumos.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Ea este atât de drăguță când râde."
    },
    {
      "text": "Băiețelul este cu adevărat drăguț."
    },
    {
      "text": "Ai un mod drăguț de a te purta cu oamenii."
    },
    {
      "text": "Bebelușul arată foarte drăguț."
    }
