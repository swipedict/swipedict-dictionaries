    "etymology": {
      "text": "Expresia „a cădea în ochi“ provine din sensul literal „a cădea în ochi“ și descrie ceva ce atrage atenția sau este remarcabil.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
