  "data": {
    "headword": "a împacheta",
    "definition": "a pune ceva într-un pachet sau într-o geantă",
    "pronunciation": "/a ɨm.paˈke.ta/",
    "etymology": {
      "text": "Verbul românesc „a împacheta“ provine din franceză „emballer“ și latină „impacare“, ambele însemnând „a împacheta“. Este legat și de cuvântul „pachet“.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu împachetez lucrurile."
    },
    {
      "text": "Am împachetat cadourile."
    },
    {
      "text": "Voi împacheta totul mâine."
    },
    {
      "text": "Aș împacheta, dacă aș avea timp."
    }
