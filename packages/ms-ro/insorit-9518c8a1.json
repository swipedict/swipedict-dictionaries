  "data": {
    "headword": "însorit",
    "definition": "Descrie vremea sau un loc unde strălucește mult soarele.",
    "pronunciation": "/ɨn.soˈrit/",
    "etymology": {
      "text": "Adjectivul românesc „însorit” derivă din verbul latin 'insolāre', care înseamnă 'a fi luminat de soare', format din prefixul 'in-' și 'sol' (soare).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Astăzi este o zi însorită."
    },
    {
      "text": "Ne bucurăm de vremea însorită la plajă."
    },
    {
      "text": "Balconul însorit este perfect pentru citit."
    },
    {
      "text": "Primăvara vremea este adesea însorită."
