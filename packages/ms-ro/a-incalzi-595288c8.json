  "data": {
    "headword": "a încălzi",
    "definition": "A furniza căldură unei camere sau unei clădiri pentru a crește temperatura.",
    "pronunciation": "/a ɨn.kɨlˈtsi/",
    "etymology": {
      "text": "Verbul românesc „a încălzi” provine din verbul latin 'calefacere', compus din 'calidus' (cald) și 'facere' (a face), având sensul de 'a face cald'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Încălzesc sufrageria în fiecare seară."
    },
    {
      "text": "Iarna trebuie să dăm drumul la încălzire."
    },
    {
      "text": "Încălzirea nu funcționează corect."
    },
    {
      "text": "Încălzim cu gaz."
    },
    {
      "text": "Poți să oprești încălzirea, te rog?"
    }
