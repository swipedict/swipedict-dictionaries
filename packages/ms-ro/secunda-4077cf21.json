  "data": {
    "headword": "secundă",
    "definition": "Unitatea de bază a timpului, egală cu 1/60 dintr-un minut.",
    "pronunciation": "/seˈkundə/",
    "etymology": {
      "text": "Cuvântul românesc „secundă” provine direct din latinescul 'secunda', care înseamnă 'a doua', fiind preluat ca unitate de măsură a timpului.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Un minut are șaizeci de secunde."
    },
    {
      "text": "Secunda este cea mai mică unitate de timp în indicarea orei."
    },
    {
      "text": "Aștept doar o secundă."
    },
    {
      "text": "Ceasul arată secunda exactă."
