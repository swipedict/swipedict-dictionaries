  "data": {
    "headword": "prințesă",
    "definition": "Fiica regelui sau a reginei, un membru feminin al familiei regale.",
    "pronunciation": "/prinˈt͡se.sə/",
    "etymology": {
      "text": "Cuvântul românesc „prințesă” provine din latinul 'princeps', prin francezul 'princesse', având sensul de 'prima' sau 'prințesă'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Prințesa poartă o rochie frumoasă."
    },
    {
      "text": "Prințesa trăiește în castel."
    },
    {
      "text": "Prințesa este fiica regelui."
    },
