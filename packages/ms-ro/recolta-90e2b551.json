  "data": {
    "headword": "recoltă",
    "definition": "Acțiunea de a aduna fructele coapte de pe câmp pentru prelucrare sau depozitare.",
    "pronunciation": "/reˈkol.tə/",
    "etymology": {
      "text": "Cuvântul românesc „recoltă” provine din latină, de la 'recolligere', care înseamnă 'a aduna din nou', format din 're-' (din nou) și 'colligere' (a aduna).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Recolta începe la sfârșitul verii."
    },
    {
      "text": "O recoltă bună asigură supraviețuirea țăranilor."
    },
    {
      "text": "Recolta a fost întârziată din cauza ploii."
    },
    {
      "text": "După recoltă, fructele sunt depozitate."
    }
