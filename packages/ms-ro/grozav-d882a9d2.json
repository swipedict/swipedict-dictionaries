  "data": {
    "headword": "grozav",
    "definition": "Un adjectiv folosit pentru a exprima ceva extraordinar, minunat sau entuziasmant.",
    "pronunciation": "/ɡroˈzav/",
    "etymology": {
      "text": "Cuvântul românesc „grozav” provine din slavona veche 'grozŭ', care însemna 'înfricoșător' sau 'puternic', dar a evoluat spre un sens pozitiv.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Concertul a fost cu adevărat grozav."
    },
    {
      "text": "Ai arătat o performanță grozavă."
    },
    {
      "text": "Vremea de azi este grozavă."
    },
    {
      "text": "Am petrecut împreună un timp grozav."
