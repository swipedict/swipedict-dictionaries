  "data": {
    "headword": "pământ",
    "definition": "Stratul superior al scoarței terestre, format din sol, nisip, argilă și materie organică.",
    "pronunciation": "/pəˈmɨnt/",
    "etymology": {
      "text": "Cuvântul românesc „pământ” provine din latinescul 'pāmentum', care însemna 'pământ' sau 'teren arabil', derivat din 'pāmen' (semănătură, sămânță).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Pământul este umed după ploaie."
    },
    {
      "text": "Săpăm o groapă în pământ."
