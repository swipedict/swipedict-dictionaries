  "data": {
    "headword": "a aluneca",
    "definition": "A se mișca alunecând, fără aderență fermă, în special vehicule sau pe suprafețe netede.",
    "pronunciation": "/a a.luˈne.ka/",
    "etymology": {
      "text": "Verbul românesc „a aluneca“ provine din latinescul „alineare“, însemnând „a alinia“ și descrie o mișcare lină, fără frecare.",
      "source": "Etymological Dictionaries, Wiktionary"
    }
  },
  "examples": [
    {
      "text": "Mașina a alunecat pe drumul înghețat."
    },
    {
      "text": "Vehiculul alunecă ușor pe asfaltul umed."
    },
    {
      "text": "La frânare, mașina poate aluneca."
    },
    {
      "text": "Anvelopele împiedică vehiculul să alunece."
    }
  ],
