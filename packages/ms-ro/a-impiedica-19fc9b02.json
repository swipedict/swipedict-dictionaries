  "data": {
    "headword": "a împiedica",
    "definition": "A face ceva astfel încât altceva să nu se întâmple sau să nu fie posibil.",
    "pronunciation": "/a ɨmpjeˈdika/",
    "etymology": {
      "text": "Verbul românesc „a împiedica“ provine din latină, de la „impedicare“, format din „in-“ (în) și „pedica“ (lanț pentru picior), cu sensul inițial de a împiedica pe cineva să se miște.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu împiedic să curgă apa."
    },
    {
      "text": "El a împiedicat accidentul."
    },
    {
      "text": "Am împiedicat catastrofa."
    },
    {
      "text": "Ei vor împiedica problema."
    },
    {
      "text": "Împiedică asta imediat!"
