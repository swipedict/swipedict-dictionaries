  "data": {
    "headword": "a se îngriji",
    "definition": "A avea grijă de cineva sau ceva, a se ocupa cu atenție.",
    "pronunciation": "/a se ɨnˈɡri.dʒi/",
    "etymology": {
      "text": "Verbul reflexiv românesc „a se îngriji” provine din prefixul latin 'in-' și 'cura' (grijă, îngrijire), însemnând 'a avea grijă'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
