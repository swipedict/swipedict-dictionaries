  "data": {
    "headword": "a încărca",
    "definition": "a umple sau a pune ceva într-un recipient sau pe un vehicul",
    "pronunciation": "/ɨn.kərˈka/",
    "etymology": {
      "text": "Verbul românesc „a încărca“ provine din latină, de la „incaricare“, care înseamnă a încărca sau a pune o povară.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
