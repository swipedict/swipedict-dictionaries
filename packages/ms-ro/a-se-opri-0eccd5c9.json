  "data": {
    "headword": "a se opri",
    "definition": "a înceta o activitate; a nu mai face ceva",
    "pronunciation": "/a se oˈpri/",
    "etymology": {
      "text": "Verbul românesc „a se opri“ derivă din latină, de la „operari“ (a lucra, a se strădui). Das reflexive Pronomen „se“ zeigt die Handlung an, die auf sich selbst bezogen ist, also „aufhören“.",
      "source": "Etymological Dictionaries, Wiktionary"
    }
  },
  "examples": [
    {
      "text": "Eu mă opresc din fumat."
    },
    {
      "text": "Te oprești, te rog?"
    },
    {
      "text": "El se oprește când este obosit."
    },
    {
      "text": "Noi ne oprim acum."
    },
    {
      "text": "Voi vă opriți, vă rog, din a vă certa?"
    },
    {
      "text": "Ei nu se opresc din vorbit."
    },
    {
      "text": "M-am oprit din a munci ieri."
    },
    {
      "text": "El se oprea din a juca în fiecare duminică."
    },
    {
      "text": "Mâine mă voi opri."
    },
    {
      "text": "M-aș opri, dacă aș putea."
    },
    {
      "text": "Oprește-te!"
    }
