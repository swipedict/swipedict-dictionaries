  "data": {
    "headword": "a paria",
    "definition": "A face o afirmație că ceva se va întâmpla, de obicei cu bani mizați.",
    "pronunciation": "/a paˈri.a/",
    "etymology": {
      "text": "Verbul românesc „a paria” provine din verbul francez 'parier', care la rândul său vine din vechiul francez 'parier', însemnând 'a concura' sau 'a paria', derivat din germanicul *pariōn.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Pariez că mâine va ploua."
    },
    {
      "text": "Am pariat bani."
