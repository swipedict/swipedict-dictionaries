  "data": {
    "headword": "frunză",
    "definition": "Partea plată, de obicei verde, a unei plante, responsabilă pentru fotosinteză.",
    "pronunciation": "/frunˈzə/",
    "etymology": {
      "text": "Cuvântul românesc „frunză” provine din latină, de la 'frons, frontis', care înseamnă 'frunză' sau 'frunziș', preluat în limba română din latină.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Frunza plantei este verde și lată."
    },
    {
      "text": "Toamna, frunzele cad din copaci."
    },
    {
      "text": "Fiecare frunză are o formă unică."
    },
    {
      "text": "Frunzele sunt importante pentru fotosinteză."
