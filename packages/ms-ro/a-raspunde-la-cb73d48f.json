  "data": {
    "headword": "a răspunde la",
    "definition": "A se ocupa de un subiect, o întrebare sau un detaliu; a reacționa la ceva.",
    "pronunciation": "/a rəsˈpundɛ la/",
    "etymology": {
      "text": "Verbul românesc „a răspunde“ provine din latină „respondere“, care înseamnă „a răspunde“ sau „a replica“. Prepoziția „la“ indică obiectul răspunsului.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu răspund la întrebarea ta."
    },
    {
      "text": "Profesorul răspunde la problemele elevilor."
    },
    {
      "text": "Vă rog să răspundeți la detalii."
    },
    {
      "text": "În discuție, el nu a răspuns la subiect."
    }
  ],
