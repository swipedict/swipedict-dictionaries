  "data": {
    "headword": "cunoștință",
    "definition": "O persoană pe care o cunoști, dar cu care nu ești neapărat prieten apropiat.",
    "pronunciation": "/ku.noʃˈtin.t͡sə/",
    "etymology": {
      "text": "Cuvântul românesc „cunoștință” provine din verbul latin 'cognoscere', care înseamnă 'a recunoaște' sau 'a cunoaște'.",
      "source": "Dicționar etimologic român"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Am multe cunoștințe în oraș."
    },
    {
      "text": "Ea este o cunoștință a surorii mele."
    },
    {
      "text": "Nu suntem prieteni, doar cunoștințe."
    },
    {
      "text": "Are multe cunoștințe de la serviciu."
    }
