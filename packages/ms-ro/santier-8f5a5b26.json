  "data": {
    "headword": "șantier",
    "definition": "Loc unde se construiește sau se repară o clădire sau o șosea.",
    "pronunciation": "/ʃanˈtjer/",
    "etymology": {
      "text": "Cuvântul românesc „șantier” provine din francezul „chantier”, care înseamnă „șantier” sau „loc de construcție” și este derivat din latinescul „cantherius”, care înseamnă „grindă” sau „bârnă”.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Șantierul este închis din cauza reparațiilor."
    },
    {
      "text": "Dimineața am vizitat șantierul."
    },
    {
      "text": "Pe șantier lucrează mulți muncitori."
    },
    {
      "text": "Șantierul este zgomotos și prăfuit."
