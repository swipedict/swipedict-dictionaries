  "data": {
    "headword": "mustată",
    "definition": "Părul facial care crește deasupra buzei superioare, cunoscut ca mustață.",
    "pronunciation": "/musˈtatə/",
    "etymology": {
      "text": "Cuvântul românesc „mustată” provine din latină, din termenul 'mustacium', care însemna la fel 'mustață', preluat din latină clasică.",
      "source": "Dicționare etimologice, studii lingvistice"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "El poartă o mustață deasă."
    },
    {
      "text": "Mustața crește deasupra buzei superioare."
    },
    {
      "text": "În trecut, mustățile erau foarte la modă."
    },
    {
      "text": "O mustață poate schimba foarte mult aspectul feței."
    }
  ],
