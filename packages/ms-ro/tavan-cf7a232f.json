    "etymology": {
      "text": "Cuvântul românesc „tavan” provine din turcescul 'tavan', care la rândul său vine din persană 'tāwān', însemnând 'tavan' sau 'acoperiș'.",
      "source": "Etymologische Wörterbücher, Sprachforschung"
    },
    "genus": "neuter"
  },
  "examples": [
