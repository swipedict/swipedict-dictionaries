  "data": {
    "headword": "tuse",
    "definition": "Expulzarea bruscă și puternică a aerului din căile respiratorii, adesea ca reflex pentru curățarea acestora.",
    "pronunciation": "/ˈtu.se/",
    "etymology": {
      "text": "Cuvântul românesc „tuse” provine din verbul latin 'tussire', care înseamnă 'a tuși' și este o imitație onomatopeică a sunetului tusei.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Tusea persistă de trei zile."
    },
    {
      "text": "La tusea uscată ajută mult să bei lichide."
    },
    {
      "text": "Doctorul a examinat tusea pacientului."
    },
    {
      "text": "Tusea poate fi un simptom al unei răceli."
    }
