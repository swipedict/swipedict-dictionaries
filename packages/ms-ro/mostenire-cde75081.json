  "data": {
    "headword": "moștenire",
    "definition": "Bunurile, drepturile și obligațiile pe care o persoană le lasă după moarte.",
    "pronunciation": "/moʃteˈnirɛ/",
    "etymology": {
      "text": "Cuvântul românesc „moștenire” provine din latină, de la 'mustinare' (derivat din 'monstrare'), dar a fost puternic influențat de limbi slave, însemnând 'moștenire'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Moștenirea a fost împărțită între moștenitori."
    },
    {
      "text": "Și-a reglementat moștenirea printr-un testament."
    },
    {
      "text": "Moștenirea cuprinde imobile și investiții financiare."
    },
    {
      "text": "Moștenitorii trebuie să administreze moștenirea."
    }
