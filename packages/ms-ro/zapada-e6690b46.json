  "data": {
    "headword": "zăpadă",
    "definition": "Precipitații înghețate, albe, formate din cristale de gheață care cad din cer.",
    "pronunciation": "/zəˈpada/",
    "etymology": {
      "text": "Cuvântul românesc „zăpadă” derivă din latinescul 'nix, nivis', printr-o mediere slavă, forma actuală provenind din slavona veche 'zъpada', care înseamnă 'cădere' sau 'precipitație'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Zăpada acoperă peisajul iarna."
    },
    {
      "text": "În ianuarie cade adesea multă zăpadă."
    },
    {
      "text": "Copiii se joacă în zăpadă."
    },
    {
      "text": "După căderea zăpezii, totul este alb."
    },
    {
      "text": "Zăpada se topește primăvara."
