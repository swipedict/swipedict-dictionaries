    "etymology": {
      "text": "Cuvântul românesc „șină” provine din latină, din 'scena', care inițial însemna 'scenă', dar a evoluat să desemneze și 'șină' (cale ferată).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
