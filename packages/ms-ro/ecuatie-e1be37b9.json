  "data": {
    "headword": "ecuație",
    "definition": "O expresie matematică care afirmă egalitatea a două expresii prin semnul egalității.",
    "pronunciation": "/ekuˈaʦje/",
    "etymology": {
      "text": "Cuvântul românesc „ecuație” provine din latină, de la 'aequatio', derivat din 'aequare' care înseamnă 'a face egal, a echilibra', reflectând sensul matematic al egalității.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Ecuația x + 2 = 5 este ușor de rezolvat."
    },
    {
      "text": "În algebră înveți cum să rezolvi ecuații."
    },
    {
      "text": "Această ecuație are două soluții."
    },
    {
      "text": "Ecuația descrie relația dintre variabile."
