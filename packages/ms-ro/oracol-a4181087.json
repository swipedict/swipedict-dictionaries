  "data": {
    "headword": "oracol",
    "definition": "O persoană sau un loc unde se dau profeții sau răspunsuri divine.",
    "pronunciation": "/oˈrakol/",
    "etymology": {
      "text": "Cuvântul românesc „oracol” provine direct din latină 'oraculum', care înseamnă 'profeție' sau 'răspuns al unui zeu' și are forme similare în multe limbi europene.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Oracolul a dat o profeție misterioasă."
    },
    {
      "text": "În Grecia antică, oamenii consultau oracolul de la Delphi."
    },
    {
      "text": "Mulți credeau în înțelepciunea oracolului."
    },
    {
      "text": "Oracolul era considerat vocea zeilor."
    }
  ],
