  "data": {
    "headword": "a judeca",
    "definition": "A forma o opinie sau o hotărâre despre ceva sau cineva, bazată pe informații sau observații.",
    "pronunciation": "/a juˈde.ka/",
    "etymology": {
      "text": "Verbul românesc „a judeca” provine din verbul latin 'iudicare', care înseamnă 'a da o judecată' sau 'a judeca', având origini în latina clasică.",
      "source": "Dictionar Etymologic Român"
    }
  },
  "examples": [
    {
      "text": "Eu judec situația ca fiind dificilă."
    },
    {
      "text": "Nu ar trebui să judeci oamenii în grabă."
    },
    {
      "text": "Profesorul judecă rezultatele examenului."
    },
    {
