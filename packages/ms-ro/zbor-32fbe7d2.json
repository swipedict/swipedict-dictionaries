    "etymology": {
      "text": "Cuvântul românesc „zbor” provine din latină, din 'exaborare', care înseamnă 'a zbura afară', și s-a format prin verbul românesc 'a zbura'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
