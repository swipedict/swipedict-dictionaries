  "data": {
    "headword": "bețișoare (de mâncat)",
    "definition": "O pereche de bastonașe subțiri folosite pentru a mânca, în special în bucătăria asiatică.",
    "pronunciation": "/bet͡siˈʃo̯are (de mɨnˈkat)/",
    "etymology": {
      "text": "Din diminutivul cuvântului 'băț', care la rândul său provine din latinul '*batius', de la 'battuere' ('a bate'). Termenul este un calc semantic folosit pentru a denumi ustensila de mâncat de origine chineză.",
      "source": "Etymologische Wörterbücher, Sprachwissenschaftliche Analysen"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Eu mănânc cu bețișoare."
    },
    {
      "text": "Bețișoarele sunt din lemn."
    },
    {
      "text": "În multe țări asiatice se folosesc bețișoare pentru mâncat."
    },
    {
      "text": "Poți să mănânci cu bețișoare?"
    }
  ],
