  "data": {
    "headword": "curent",
    "definition": "Flux de energie electrică sau de apă; în principal energie electrică care circulă printr-un conductor.",
    "pronunciation": "/kuˈrent/",
    "etymology": {
      "text": "Cuvântul românesc „curent” provine din latină, din participiul prezent 'currens' al verbului 'currere' (a alerga, a curge), însemnând inițial 'care curge' sau 'curgător'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Curentul trece prin cablu."
    },
    {
      "text": "Fără curent, aparatul nu funcționează."
    },
    {
      "text": "Râul are un curent puternic."
    },
    {
      "text": "Azi a fost pană de curent."
