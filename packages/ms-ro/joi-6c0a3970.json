  "data": {
    "headword": "joi",
    "definition": "A patra zi a săptămânii, numită după zeul roman Iupiter (Jupiter).",
    "pronunciation": "/ˈʒoj/",
    "etymology": {
      "text": "Cuvântul românesc „joi” provine din latinul 'Jovis dies', care înseamnă 'ziua lui Jupiter', zeul roman al cerului și tunetului.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Joi este a patra zi a săptămânii."
    },
    {
      "text": "Joi am liber."
    },
    {
      "text": "Joia merg la cinema."
    },
    {
      "text": "Joi urmează după miercuri."
    }
