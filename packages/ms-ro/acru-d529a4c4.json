  "data": {
    "headword": "acru",
    "definition": "Descrie un gust caracterizat prin prezența acidității, de exemplu ca la lămâi sau oțet.",
    "pronunciation": "/ˈakru/",
    "etymology": {
      "text": "Adjectivul românesc „acru” provine din latinescul 'acer', care înseamnă 'ascuțit' sau 'amar' și se referă la un gust ascuțit sau acru.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Lămâia are gust acru."
    },
    {
      "text": "Oțetul este foarte acru."
    },
    {
      "text": "Unele fructe sunt acre și răcoritoare."
    },
    {
      "text": "Iaurtul are un gust ușor acru."
