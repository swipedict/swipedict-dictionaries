  "data": {
    "headword": "mamă",
    "definition": "părinte de sex feminin al unui copil",
    "pronunciation": "/ˈmamə/",
    "etymology": {
      "text": "Cuvântul românesc „mamă“ provine din slavicul „ma“, folosit în multe limbi slave pentru „mamă“, cu rădăcini indo-europene comune.",
      "source": "Etymological Dictionaries, Wiktionary"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Mama mea gătește cea mai bună mâncare."
    },
    {
      "text": "Mama joacă un rol esențial în familie."
    },
    {
      "text": "Îmi iubesc mama."
    },
    {
      "text": "Ea este o mamă minunată."
    },
    {
      "text": "Mama și copilul merg adesea la plimbare."
    },
    {
      "text": "Mama are întotdeauna timp pentru copii."
    }
