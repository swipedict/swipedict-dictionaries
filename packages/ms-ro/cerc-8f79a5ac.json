  "data": {
    "headword": "cerc",
    "definition": "O figură geometrică care cuprinde toate punctele aflate la aceeași distanță de un punct central.",
    "pronunciation": "/tʃerk/",
    "etymology": {
      "text": "Cuvântul românesc „cerc” provine din latină 'circus', care inițial însemna 'inel' sau 'circ', referindu-se la un spațiu circular.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Cercul are o rază de cinci centimetri."
    },
    {
      "text": "Desenăm un cerc pe hârtie."
    },
    {
      "text": "Circumferința cercului este de 31,4 centimetri."
    },
    {
      "text": "Un cerc este o formă perfect rotundă."
    }
