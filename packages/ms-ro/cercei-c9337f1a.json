  "data": {
    "headword": "cercei",
    "definition": "Un obiect de podoabă purtat la ureche, de obicei sub forma unui mic inel sau a unui știft.",
    "pronunciation": "/tʃerˈtʃej/",
    "etymology": {
      "text": "Cuvântul românesc „cercei” provine din latină, de la 'circus', care însemna inițial 'inel' sau 'cerc', referindu-se la forma rotundă a podoabei.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Ea poartă cercei frumoși din aur."
    },
    {
      "text": "Cerceiul este rotund și strălucitor."
    },
    {
      "text": "Mi-am cumpărat cercei noi."
    },
    {
      "text": "Cerceii pot fi făcuți din diferite materiale."
