    "etymology": {
      "text": "Verbul românesc „a exporta“ derivă din latină, din „exportare“, având sensul de „a duce bunuri în străinătate“ și este folosit frecvent în domeniul economic.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
