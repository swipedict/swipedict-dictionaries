  "data": {
    "headword": "rău",
    "definition": "Care are o calitate proastă, este neplăcut sau negativ în privința stării, performanței sau moralității.",
    "pronunciation": "/rəu/",
    "etymology": {
      "text": "Cuvântul românesc „rău” provine dintr-o evoluție a adjectivului latin 'malus', influențat de substratul dacian, cu sensul de 'rău' sau 'nefavorabil'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
