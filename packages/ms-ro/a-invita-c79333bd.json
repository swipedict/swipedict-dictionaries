  "data": {
    "headword": "a invita",
    "definition": "a cere sau a solicita cuiva să participe la un eveniment",
    "pronunciation": "/a in.viˈta/",
    "etymology": {
      "text": "Verbul românesc „a invita“ provine din latină, de la „invitaré“, care înseamnă „a chema“ sau „a invita“. Este folosit pentru a solicita prezența cuiva la un eveniment.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
