    "etymology": {
      "text": "Cuvântul românesc „plapumă” provine probabil din slavă, din 'plapuma', care înseamnă 'pătură' sau 'cuvertură'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
