    "etymology": {
      "text": "Expresia românească „a fi valabil“ provine din latină „validus“, care înseamnă „puternic“ sau „valid“, referindu-se la valabilitate.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
