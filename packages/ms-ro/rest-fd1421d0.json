    "etymology": {
      "text": "Cuvântul românesc „rest” provine din substantivul latin 'restare', care înseamnă 'a rămâne', referindu-se la suma rămasă după o plată.",
      "source": "Dicționare etimologice românești"
    },
    "genus": "neuter"
  },
  "examples": [
