  "data": {
    "headword": "prinț",
    "definition": "Un membru masculin al unei familii regale, de obicei fiul regelui sau al reginei.",
    "pronunciation": "/prinʦ/",
    "etymology": {
      "text": "Cuvântul românesc „prinț” provine direct din latină 'princeps', care înseamnă 'primul' sau 'conducător', fiind preluat prin limba română veche.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Prințul a vizitat castelul."
    },
    {
      "text": "Prințul este fiul regelui."
    },
    {
      "text": "Multe basme vorbesc despre un prinț și o prințesă."
    },
    {
      "text": "Prințul va fi într-o zi rege."
    }
