    "etymology": {
      "text": "Cuvântul românesc „însetat” derivă din verbul 'a înseta', format din prefixul 'în-' și verbul latin 'exsaturare' (a satura), indicând o stare de sete.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
