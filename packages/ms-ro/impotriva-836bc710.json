  "data": {
    "headword": "împotriva",
    "definition": "Prepoziție care exprimă opoziție, direcție sau apropiere față de ceva.",
    "pronunciation": "/ɨmpoˈtriva/",
    "etymology": {
      "text": "Cuvântul românesc „împotriva” provine din expresia latină 'in proterva', unde 'proterva' însemna 'îndrăzneț, obraznic', evoluând spre o prepoziție ce exprimă opoziție.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Sunt împotriva propunerii."
    },
    {
      "text": "Mașina se lovește de perete."
    },
    {
      "text": "El luptă împotriva nedreptății."
    },
    {
      "text": "Vântul bate spre fereastră."
    }
