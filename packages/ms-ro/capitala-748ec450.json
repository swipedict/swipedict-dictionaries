  "data": {
    "headword": "capitală",
    "definition": "Orașul principal al unei țări, unde se află guvernul.",
    "pronunciation": "/kapiˈtala/",
    "etymology": {
      "text": "Cuvântul românesc „capitală” provine din latinescul 'capitale', derivat din 'caput' (cap), care inițial însemna 'cap' sau 'principal' și a fost apoi folosit pentru a desemna orașul principal.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Berlin este capitala Germaniei."
    },
