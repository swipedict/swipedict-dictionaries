  "data": {
    "headword": "pisică",
    "definition": "Un animal mic, de obicei domesticit, cu blană moale, ținut adesea ca animal de companie.",
    "pronunciation": "/piˈsi.kə/",
    "etymology": {
      "text": "Cuvântul românesc „pisică” provine din latinul 'pīca', care inițial însemna 'coțofană', dar a fost transferat în timp pentru a desemna pisica, posibil sub influența limbilor slave.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Pisica doarme toată ziua."
    },
    {
      "text": "Pisica mea este foarte jucăușă."
    },
    {
      "text": "Pisica aleargă după un șoarece."
    },
    {
      "text": "Am văzut o pisică neagră."
    }
