  "data": {
    "headword": "șarpe",
    "definition": "Un reptil lung, fără picioare, care se târăște.",
    "pronunciation": "/ˈʃar.pe/",
    "etymology": {
      "text": "Cuvântul românesc „șarpe” provine din latină 'serpens, serpentis', care înseamnă 'șarpe'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Șarpele se târăște prin iarbă."
    },
    {
      "text": "Unele șerpi sunt veninoși."
    },
    {
      "text": "Șarpele nu are picioare."
    },
    {
      "text": "În basme, șarpele simbolizează adesea viclenia."
    }
