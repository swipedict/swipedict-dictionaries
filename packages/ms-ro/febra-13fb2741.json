  "data": {
    "headword": "febră",
    "definition": "O stare de temperatură corporală ridicată, de obicei simptom al unei boli.",
    "pronunciation": "/feˈbrə/",
    "etymology": {
      "text": "Cuvântul românesc „febră” provine direct din latină, din 'febris', care înseamnă 'febră'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Are febră mare."
    },
    {
      "text": "Febra este un semn că organismul luptă împotriva unei boli."
    },
    {
      "text": "Febra a scăzut ieri."
    },
    {
      "text": "La febră trebuie să bei multă apă."
    }
