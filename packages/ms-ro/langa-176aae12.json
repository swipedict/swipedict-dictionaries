  "data": {
    "headword": "lângă",
    "definition": "Indică faptul că ceva este alături de altceva, în apropiere.",
    "pronunciation": "/lɨŋˈɡə/",
    "etymology": {
      "text": "Cuvântul românesc „lângă” provine din latinul 'latus' (parte, lateral), evoluând spre adverbul 'lângă', care înseamnă 'lângă', 'alături de'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Casa este lângă școală."
    },
    {
      "text": "Stau lângă prietenul meu."
    },
    {
      "text": "Parcul se află lângă râu."
    },
    {
      "text": "Lângă mașină este o bicicletă."
    }
