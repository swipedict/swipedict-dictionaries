    "headword": "a se certa",
    "definition": "a avea o dispută sau a se combate",
    "pronunciation": "/a se ˈt͡ʃerta/",
    "etymology": {
      "text": "Verbul reflexiv românesc „a se certa“ derivă din latinescul „certare“, care înseamnă „a lupta, a se certa“.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Mă cert cu el."
    },
    {
      "text": "Te cerți și tu din nou astăzi?"
    },
    {
      "text": "El se ceartă mereu cu părinții săi."
    },
    {
      "text": "Ne certăm din principiu."
    },
    {
      "text": "Vă certați des?"
    },
    {
      "text": "Ei nu se ceartă niciodată pe bani."
    },
    {
      "text": "M-am certat săptămâna trecută cu ea."
    },
    {
      "text": "Mă voi certa mâine cu tine."
    },
    {
      "text": "Nu m-aș certa dacă aș ști că ai dreptate."
    },
    {
      "text": "Nu te certa!"
    }
