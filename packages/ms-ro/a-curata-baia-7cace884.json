    "etymology": {
      "text": "Verbul românesc „a curăța“ derivă din latină 'curare', care înseamnă 'a îngriji', iar 'baia' provine din latină 'balneum', care înseamnă 'baie'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
