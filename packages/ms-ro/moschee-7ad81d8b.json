  "data": {
    "headword": "moschee",
    "definition": "O clădire folosită ca loc de rugăciune pentru musulmani.",
    "pronunciation": "/mosˈke.e/",
    "etymology": {
      "text": "Cuvântul românesc „moschee” este împrumutat din turcescul 'mescit', care provine din araba 'masjid' și înseamnă 'loc de rugăciune'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Moscheea este un loc important pentru musulmani."
    },
    {
      "text": "Am vizitat moscheea mare din oraș."
    },
    {
      "text": "Minaretul moscheii este foarte înalt."
    },
    {
      "text": "În moschee, credincioșii se roagă împreună."
