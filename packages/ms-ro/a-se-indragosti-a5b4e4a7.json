    "etymology": {
      "text": "Verbul românesc „a se îndrăgosti” provine din substantivul latin 'dragoste', care înseamnă 'dragoste'. Prefixul 'în-' și pronumele reflexiv 'se' indică intrarea într-o stare.",
      "source": "Dicționare etimologice, studii lingvistice"
    }
  },
