    "etymology": {
      "text": "Cuvântul românesc „provocare” provine din verbul latin 'provocare', care înseamnă 'a provoca' sau 'a chema la luptă'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
