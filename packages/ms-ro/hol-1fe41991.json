  "data": {
    "headword": "hol",
    "definition": "Un spațiu lung și îngust într-o casă, care leagă alte camere, adesea un coridor sau o sală.",
    "pronunciation": "/hol/",
    "etymology": {
      "text": "Cuvântul românesc „hol” provine din germană, din 'Hohl', care înseamnă 'gol' sau 'spațiu gol', fiind un împrumut.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Holul este foarte lat."
    },
    {
      "text": "În hol sunt agățate multe poze."
    },
    {
      "text": "Holul leagă camerele."
    },
    {
      "text": "Te rog să aștepți în hol."
