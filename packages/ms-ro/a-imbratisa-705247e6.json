  "data": {
    "headword": "a îmbrățișa",
    "definition": "a strânge pe cineva în brațe pentru a arăta afecțiune sau consolare",
    "pronunciation": "/ɨm.brəˈt͡ʃi.ʃa/",
    "etymology": {
      "text": "Verbul românesc „a îmbrățișa“ derivă din latinescul „amplecti“, care înseamnă „a cuprinde cu brațele“, indicând o îmbrățișare caldă și afectuoasă.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Îl îmbrățișez pe prietenul meu."
    },
    {
      "text": "Îmbrățișezi fratele tău?"
    },
    {
      "text": "Ea îmbrățișează mama ei."
    },
    {
      "text": "Noi îmbrățișăm oaspeții."
    },
    {
      "text": "Îmbrățișați părinții voștri?"
