  "data": {
    "headword": "săgeată",
    "definition": "Un obiect lung și subțire, ascuțit la un capăt, folosit ca muniție pentru arc.",
    "pronunciation": "/səˈɡe̯a.tə/",
    "etymology": {
      "text": "Cuvântul românesc „săgeată” provine din latinul 'sagitta', care înseamnă tot 'săgeată' și a fost preluat din latina clasică.",
      "source": "Dicționare etimologice, Analize lingvistice"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Săgeata zboară repede prin aer."
    },
    {
      "text": "A întins arcul și a tras săgeata."
    },
    {
      "text": "Săgețile erau pregătite în teacă."
    },
    {
      "text": "O săgeată indică direcția."
    }
