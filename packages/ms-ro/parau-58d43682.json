  "data": {
    "headword": "pârâu",
    "definition": "Un curs mic de apă naturală, de obicei mai mic decât un râu.",
    "pronunciation": "/pɨrˈɨw/",
    "etymology": {
      "text": "Cuvântul românesc „pârâu“ provine din latinescul „perrivus“, care însemna „pârâu mic“ sau „afluent“, evoluând în limba română la „pârâu“.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Pârâul curge prin pădure."
    },
    {
      "text": "Am jucat la pârâu."
    },
    {
      "text": "Pârâul este adesea foarte mic vara."
    },
    {
      "text": "Peștii trăiesc în pârâu."
    }
