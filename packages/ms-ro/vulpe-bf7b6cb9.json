  "data": {
    "headword": "vulpe",
    "definition": "Un mamifer sălbatic de dimensiuni mici până la medii, cu blană roșie și coadă stufoasă, cunoscut pentru istețimea sa.",
    "pronunciation": "/ˈvul.pe/",
    "etymology": {
      "text": "Cuvântul românesc „vulpe” provine din latină, din 'vulpes', care desemna același animal, având rădăcini indo-europene.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Vulpea este un animal isteț."
    },
    {
      "text": "În pădure se văd adesea vulpi."
    },
    {
      "text": "Culoarea roșie a vulpii este caracteristică."
    },
    {
      "text": "Vulpea are o coadă stufoasă."
    }
