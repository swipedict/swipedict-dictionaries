  "data": {
    "headword": "dacă",
    "definition": "O conjuncție folosită pentru a introduce propoziții subordonate condiționale sau temporale, echivalentul lui 'wenn' în germană.",
    "pronunciation": "/ˈdaka/",
    "etymology": {
      "text": "Cuvântul românesc 'dacă' provine probabil din latinescul 'dare' (a da), dar s-a dezvoltat în timp ca o conjuncție pentru condiții.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Dacă plouă, stau acasă."
    },
    {
      "text": "Te sun când sunt acasă."
    },
    {
      "text": "Dacă ai timp, ne putem întâlni."
    },
    {
      "text": "Când sunt obosit, beau cafea."
    }
