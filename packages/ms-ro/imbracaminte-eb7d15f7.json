  "data": {
    "headword": "îmbrăcăminte",
    "definition": "Toate tipurile de haine pe care le porți pentru a-ți acoperi corpul.",
    "pronunciation": "/ɨmbrəˈkəmɨnt͡se/",
    "etymology": {
      "text": "Cuvântul românesc „îmbrăcăminte” derivă din verbul „a îmbrăca”, împrumutat din latină 'imbricare' (a acoperi, a suprapune), având sensul de îmbrăcăminte.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Iarna se poartă îmbrăcăminte groasă."
    },
    {
      "text": "Îmbrăcămintea este curată și ordonată."
    },
    {
      "text": "A cumpărat îmbrăcăminte nouă pentru călătorie."
    },
    {
      "text": "Îmbrăcămintea protejează împotriva frigului și vântului."
    }
