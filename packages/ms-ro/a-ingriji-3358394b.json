  "data": {
    "headword": "a îngriji",
    "definition": "a se ocupa de cineva sau a-l sprijini",
    "pronunciation": "/a ɨn.griˈʒi/",
    "etymology": {
      "text": "Verbul românesc „a îngriji“ provine din cuvântul vechi românesc „îngrijire“, care înseamnă grijă sau îngrijire, având rădăcini latine.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu îngrijesc elevii noi."
    },
    {
      "text": "Îngrijeşti hainele pentru eveniment?"
    },
    {
      "text": "El îngrijeşte bunicii săi."
    },
    {
      "text": "Noi îngrijim cu plăcere copiii din grădiniță."
    },
    {
      "text": "Îngrijiţi animalele din grădina zoologică?"
    },
    {
      "text": "Ei îngrijesc foarte bine clienţii."
    },
    {
      "text": "Am îngrijit copiii pe parcursul călătoriei."
    },
    {
      "text": "Ei îngrijeau oaspeţii în timpul petrecerii."
    },
    {
      "text": "Voi îngriji animalele din adăpost."
    },
    {
      "text": "Aş îngriji angajaţii, dacă aş avea timp."
    }
