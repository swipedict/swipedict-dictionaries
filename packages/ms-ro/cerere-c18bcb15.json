    "etymology": {
      "text": "Cuvântul românesc „cerere” provine din verbul „a cere”, care înseamnă „a cere” sau „a solicita”, cu origini latine.",
      "source": "Dicționar etimologic român"
    },
    "genus": "feminine"
  },
  "examples": [
