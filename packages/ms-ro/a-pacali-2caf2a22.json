  "data": {
    "headword": "a păcăli",
    "definition": "A înșela sau a face pe cineva de râs, în mod colocvial.",
    "pronunciation": "/a pəkəˈli/",
    "etymology": {
      "text": "Verbul românesc „a păcăli” provine din latină, din verbul 'pacare' care însemna 'a calma', dar a evoluat spre sensul de 'a păcăli' sau 'a înșela'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "M-a păcălit complet."
    },
    {
      "text": "Nu te face de râs, ești păcălit."
    },
    {
      "text": "Cred că ne păcălește pe toți."
    },
    {
      "text": "Nu mai încerca să mă păcălești!"
    }
  ],
