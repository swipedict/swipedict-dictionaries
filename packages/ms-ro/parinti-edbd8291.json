  "data": {
    "headword": "părinți",
    "definition": "Mama și tatăl unui copil; cei care îl nasc.",
    "pronunciation": "/pəˈrintsʲ/",
    "etymology": {
      "text": "Cuvântul românesc „părinți” provine din latină, de la 'parens, parentis', care înseamnă 'părinte' sau 'cel care naște'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Părinții au grijă de copil."
    },
    {
      "text": "Părinții mei sunt foarte prietenoși."
    },
    {
      "text": "Părinții ar trebui să-și susțină copiii."
    },
