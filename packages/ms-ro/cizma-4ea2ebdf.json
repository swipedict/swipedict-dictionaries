    "etymology": {
      "text": "Cuvântul românesc „cizmă” provine din turcescul 'çizme', care la rândul său este împrumutat din persanul 'čizm', însemnând 'cizmă' sau 'încălțăminte înaltă'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
