  "data": {
    "headword": "trotuar",
    "definition": "Ein befestigter Weg am Straßenrand, der für Fußgänger bestimmt ist.",
    "pronunciation": "/troˈtwar/",
    "etymology": {
      "text": "Cuvântul românesc „trotuar” provine din franceza 'trottoir', care înseamnă trotuar sau alee pentru pietoni.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Trotuarul este rezervat pietonilor."
    },
    {
      "text": "Te rog folosește trotuarul, nu strada."
    },
    {
      "text": "Trotuarul este curat și bine luminat."
    },
    {
      "text": "Copiii merg în siguranță pe trotuar la școală."
    }
