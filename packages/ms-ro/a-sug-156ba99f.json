  "data": {
    "headword": "a sug",
    "definition": "a ridica sau a capta ceva cu ajutorul unui aparat de suctiune",
    "pronunciation": "/a suɡ/",
    "etymology": {
      "text": "Verbul românesc „a sug“ derivă din latinul „sugere“, care înseamnă „a aspira“. Este folosit pentru a descrie acțiunea de a prelua lichide sau aer prin supt.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu sug apa."
    },
    {
      "text": "Sugă bine aspiratorul?"
    },
    {
      "text": "Planta suge apă din pământ."
    },
    {
      "text": "Noi sugem aerul."
    },
    {
      "text": "Sugăți pulberea de budincă prin pai?"
    },
    {
      "text": "Bebelușii sug la sticlele lor."
    },
    {
      "text": "Am sugerat apa."
    },
    {
      "text": "El sugea în fiecare dimineață cu aspiratorul."
    },
    {
      "text": "Voi sugera apa."
    },
    {
      "text": "Aș sugera apa dacă aș avea o pompă."
    },
    {
      "text": "Suge aerul!"
    }
