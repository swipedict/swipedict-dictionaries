    "etymology": {
      "text": "Verbul românesc „a se plânge“ provine din latină, de la „plangere“, care înseamnă a plânge sau a se plânge, exprimând durerea personală.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
