    "etymology": {
      "text": "Verbul reflexiv românesc „a se dezbrăca“ este format din prefixul „de-“ și „zbrăca“ (a îmbrăca), însemnând a se dezbrăca.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
