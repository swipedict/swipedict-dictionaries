  "data": {
    "headword": "căciulă",
    "definition": "O piesă de îmbrăcăminte pentru cap, de obicei din material textil, care acoperă capul și uneori urechile, folosită pentru a proteja de frig.",
    "pronunciation": "/kəˈt͡ʃju.lə/",
    "etymology": {
      "text": "Cuvântul românesc „căciulă” provine din slavona veche 'kačula', care desemna un tip de căciulă sau acoperământ pentru cap.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Iarna port întotdeauna o căciulă călduroasă."
    },
    {
      "text": "Căciula protejează urechile de frig."
    },
    {
      "text": "Și-a uitat căciula în casă."
    },
    {
      "text": "Copiii poartă adesea căciuli colorate."
    }
