    "etymology": {
      "text": "Adjectivul românesc „nesigur” provine din prefixul latin de negație 'ne-' și din 'sigur', derivat din latină 'securus', care înseamnă 'sigur'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
