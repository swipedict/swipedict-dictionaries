  "data": {
    "headword": "a mângâia",
    "definition": "A atinge ușor și cu blândețe pe cineva sau ceva, exprimând afecțiune.",
    "pronunciation": "/a mɨnɡˈɨa/",
    "etymology": {
      "text": "Verbul românesc „a mângâia” derivă din verbul latin 'manicare', care însemna 'a atinge cu mâna', preluat în limba română prin evoluția fonetică și semantică specifică.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu mângâi pisica ușor."
    },
    {
      "text": "Ea îi mângâie câinele peste cap."
    },
    {
      "text": "Bebelușul iubește să fie mângâiat."
    },
    {
      "text": "Mângâie iepurele cu grijă."
    },
    {
      "text": "El îi mângâie părul ca să o liniștească."
    }
  ],
