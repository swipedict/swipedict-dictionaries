  "data": {
    "headword": "unchi",
    "definition": "Fratele unuia dintre părinți sau soțul mătușii.",
    "pronunciation": "/ˈun.ki/",
    "etymology": {
      "text": "Cuvântul românesc „unchi” provine din latină 'avunculus', desemnând în mod specific fratele mamei. Este o moștenire directă a limbii latine în română.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Unchiul meu locuiește în Berlin."
    },
    {
      "text": "Unchiul mamei mele este foarte drăguț."
    },
