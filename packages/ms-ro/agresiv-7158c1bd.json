  "data": {
    "headword": "agresiv",
    "definition": "O atitudine sau comportament caracterizat prin tendința de a ataca, de a impune voința sau de ostilitate.",
    "pronunciation": "/aɡreˈsiv/",
    "etymology": {
      "text": "Adjectivul românesc „agresiv” provine direct din latinescul 'aggresivus', derivat din verbul 'aggredi', care înseamnă 'a ataca'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "El a manifestat un comportament agresiv în timpul certului."
    },
    {
      "text": "Publicitatea agresivă deranjează mulți clienți."
    },
    {
      "text": "Animalele agresive pot fi periculoase."
    },
    {
      "text": "Ea s-a apărat agresiv împotriva criticii."
    }
