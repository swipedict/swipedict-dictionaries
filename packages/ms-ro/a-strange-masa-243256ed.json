  "data": {
    "headword": "a strânge masa",
    "definition": "A lua de pe masă vesela și tacâmurile după ce s-a mâncat.",
    "pronunciation": "/a strɨn.d͡ʒe ˈmasa/",
    "etymology": {
      "text": "Verbul românesc „a strânge” provine din latinescul 'stringere', care înseamnă 'a strânge' sau 'a lega'. Substantivul „masa” derivă din latinescul 'mensa', însemnând 'masă'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Te rog, strânge masa, am terminat de mâncat."
    },
    {
      "text": "După masă, ea strânge întotdeauna masa."
    },
    {
      "text": "Poți să strângi masa?"
    },
    {
      "text": "Strângem masa împreună."
