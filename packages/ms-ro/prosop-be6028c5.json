  "data": {
    "headword": "prosop",
    "definition": "O bucată de material textil folosită pentru a usca mâinile sau corpul.",
    "pronunciation": "/proˈsop/",
    "etymology": {
      "text": "Cuvântul românesc „prosop” provine din grecescul 'πρόσωπον' (prósōpon), care inițial însemna 'față', dar a ajuns să desemneze și 'bucată de material pentru uscare'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Îmi usuc mâinile cu prosopul."
    },
    {
      "text": "Prosopul atârnă lângă chiuvetă."
    },
    {
      "text": "Te rog, dă-mi un prosop curat."
    },
    {
      "text": "După înot, folosesc întotdeauna prosopul meu."
    }
