  "data": {
    "headword": "a răspândi",
    "definition": "A face cunoscut sau a transmite o informație, o veste sau un zvon către un număr mare de persoane.",
    "pronunciation": "/a rəs.pɨnˈdi/",
    "etymology": {
      "text": "Verbul românesc „a răspândi” provine din verbul latin 'pandere', care înseamnă 'a întinde, a răspândi', cu prefixul 'ră-' care intensifică acțiunea.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Mulți oameni răspândesc zvonul rapid."
    },
    {
      "text": "El a răspândit zvonul ieri."
    },
    {
      "text": "Oamenii răspândeau vești pe cale orală în trecut."
    },
    {
      "text": "Ei vor răspândi zvonul în curând."
    },
    {
      "text": "Nu răspândi zvonuri false!"
    }
