  "data": {
    "headword": "enervat",
    "definition": "Stare de iritare sau enervare, genervt bedeutet verärgert oder gereizt.",
    "pronunciation": "/e.neɾˈvat/",
    "etymology": {
      "text": "Cuvântul românesc „enervat” provine din latină 'enervare', care înseamnă 'a slăbi nervii' sau 'a irita'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Sunt enervat din cauza zgomotului."
    },
    {
      "text": "Ea pare enervată."
    },
    {
      "text": "A fi enervat înseamnă a fi iritat sau supărat."
    },
    {
      "text": "S-a enervat pentru că internetul nu funcționa."
