  "data": {
    "headword": "iepure",
    "definition": "Un mamifer mic, cu urechi lungi, adesea ținut ca animal de companie.",
    "pronunciation": "/jeˈpu.re/",
    "etymology": {
      "text": "Cuvântul românesc „iepure” provine din latină, din 'lepus, leporis', care înseamnă 'iepure', cu prefixul 'i-' adăugat în română.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Iepurele aleargă prin grădină."
    },
    {
      "text": "Am un iepure ca animal de companie."
    },
    {
      "text": "Iepurii au urechi lungi."
    },
    {
      "text": "Iepurele mănâncă morcovi."
    }
