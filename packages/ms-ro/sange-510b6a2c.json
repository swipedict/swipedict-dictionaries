    "etymology": {
      "text": "Cuvântul românesc „sânge” provine din latinul 'sanguis', care înseamnă 'sânge' și are o rădăcină indo-europeană *sengʷ-.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
