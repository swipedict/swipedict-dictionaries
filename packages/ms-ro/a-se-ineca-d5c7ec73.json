    "etymology": {
      "text": "Verbul reflexiv românesc „a se îneca“ derivă din latină, de la „innaurare“, cu sensul de „a se scufunda“ sau „a se îneca“.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
