  "data": {
    "headword": "înger",
    "definition": "O ființă spirituală considerată mesager al lui Dumnezeu în multe religii.",
    "pronunciation": "/ˈɨn.d͡ʒer/",
    "etymology": {
      "text": "Cuvântul românesc „înger” provine din grecescul 'angelos', care înseamnă 'mesager', pătruns în limbile romanice prin latină.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Îngerul a apărut într-un vis."
    },
    {
      "text": "Ea crede în îngeri și îngeri păzitori."
    },
    {
      "text": "Îngerii sunt adesea reprezentați ca ființe de lumină."
    },
    {
      "text": "Îngerul mic are aripi."
    }
