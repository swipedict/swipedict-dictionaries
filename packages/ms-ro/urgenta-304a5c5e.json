  "data": {
    "headword": "urgență",
    "definition": "O situație care necesită acțiune imediată pentru a preveni un pericol sau un prejudiciu.",
    "pronunciation": "/urˈdʒen.t͡sə/",
    "etymology": {
      "text": "Cuvântul românesc „urgență” provine din latină, de la 'urgentia', derivat din verbul 'urgere', care înseamnă 'a presa' sau 'a obliga'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "În caz de urgență, vă rugăm să sunați la pompieri."
    },
    {
      "text": "Spitalul are o secție de urgență."
    },
    {
      "text": "Într-o urgență, fiecare secundă contează."
    },
    {
      "text": "Urgențele necesită acțiuni rapide."
    }
