  "data": {
    "headword": "mormânt",
    "definition": "Loc unde este îngropată o persoană decedată; o groapă pentru odihna morților.",
    "pronunciation": "/morˈmɨnt/",
    "etymology": {
      "text": "Cuvântul românesc „mormânt” derivă din latinul 'monumentum', care inițial desemna un monument sau o amintire, iar mai târziu a căpătat sensul de loc de îngropăciune.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Mormântul este împodobit cu flori."
    },
    {
      "text": "Am vizitat mormântul bunicilor noștri."
    },
    {
      "text": "Mormântul se află în cimitir la marginea localității."
    },
    {
      "text": "Mulți oameni pun lumânări pe mormânt."
    }
