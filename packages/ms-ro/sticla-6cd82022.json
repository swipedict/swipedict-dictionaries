    "headword": "sticlă",
    "definition": "Un recipient din sticlă, adesea folosit pentru a bea sau a păstra lichide.",
    "pronunciation": "/ˈstɪklə/",
    "etymology": {
      "text": "Cuvântul „sticlă“ provine din latinescul „vitrum“, referindu-se la materialul transparent folosit pentru recipiente.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
