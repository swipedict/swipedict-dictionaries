    "etymology": {
      "text": "Cuvântul românesc „cinci” provine din latină, din 'quinque', care desemna cifra 5 și s-a transformat fonetic în 'cinci'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
