  "data": {
    "headword": "îngheț",
    "definition": "Fenomen meteorologic când temperatura scade sub punctul de îngheț și se formează gheață.",
    "pronunciation": "/ɨnˈɡe̯t͡s/",
    "etymology": {
      "text": "Cuvântul românesc „îngheț” provine din verbul latin 'ingelare', compus din prefixul 'in-' (înăuntru) și 'gelare' (a îngheța), având sensul de 'a îngheța'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Iarna apare adesea îngheț noaptea."
    },
    {
      "text": "Înghețul a deteriorat plantele."
    },
    {
      "text": "La îngheț trebuie să conduci cu grijă."
    },
    {
      "text": "Înghețul formează cristale frumoase de gheață."
    }
  ],
