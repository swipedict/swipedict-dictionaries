  "data": {
    "headword": "preot",
    "definition": "O persoană care deține o funcție religioasă și săvârșește ritualuri în cadrul unei biserici sau comunități religioase.",
    "pronunciation": "/preˈot/",
    "etymology": {
      "text": "Cuvântul românesc „preot” provine din latină 'presbyter', preluat prin grecescul 'presbyteros', care inițial însemna 'bătrân' sau 'preot'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Preotul ține slujba în biserică."
    },
    {
      "text": "Preotul binecuvântează credincioșii."
    },
    {
      "text": "Preotul poartă o robă tradițională."
    },
    {
      "text": "Mulți oameni caută sfaturi la preot."
    }
