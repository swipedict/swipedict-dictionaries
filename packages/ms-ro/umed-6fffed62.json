  "data": {
    "headword": "umed",
    "definition": "Acoperit cu o cantitate mică de apă sau lichid; ușor umed.",
    "pronunciation": "/uˈmed/",
    "etymology": {
      "text": "Adjectivul românesc „umed” provine din cuvântul latin 'humidus', care înseamnă 'umed' sau 'îmbibat cu apă', derivat din rădăcina indo-europeană *dhghem- ce înseamnă pământ sau umed.",
      "source": "Dicționare etimologice, Analize lingvistice"
    }
  },
  "examples": [
    {
      "text": "Solul este încă umed după ploaie."
    },
    {
      "text": "Clima umedă favorizează creșterea plantelor."
    },
    {
      "text": "Aerul umed se simte greu."
    },
    {
      "text": "După înot, prosopul meu era încă umed."
    }
