    "etymology": {
      "text": "Cuvântul românesc „vânzător” provine din verbul latin 'vendere', care înseamnă 'a vinde'. Forma a fost creată prin derivarea cu sufixul agentiv românesc '-ător'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
