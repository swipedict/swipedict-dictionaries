  "data": {
    "headword": "întrebare",
    "definition": "O propoziție sau expresie prin care se solicită o informație sau un răspuns.",
    "pronunciation": "/ɨntreˈbare/",
    "etymology": {
      "text": "Cuvântul românesc „întrebare” provine din verbul 'a întreba', împrumutat din latină 'interrogare', care înseamnă 'a întreba'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Am o întrebare despre subiect."
    },
    {
      "text": "Pot să-ți pun o întrebare?"
    },
    {
      "text": "Întrebarea este dificil de răspuns."
    },
    {
