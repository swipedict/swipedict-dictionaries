    "etymology": {
      "text": "Cuvântul românesc „asteroid” este împrumutat direct din greacă, prin latină, cu sensul de 'asemănător unei stele'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
