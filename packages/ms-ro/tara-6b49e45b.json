  "data": {
    "headword": "țară",
    "definition": "Un teritoriu delimitat, adesea cu guvernare și cultură proprie.",
    "pronunciation": "/t͡səˈrə/",
    "etymology": {
      "text": "Cuvântul românesc „țară” provine din slavonă 'čarь', care însemna 'teritoriu de stăpânire' și a căpătat în română sensul de 'țară, stat'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Germania este o țară în Europa."
    },
    {
      "text": "Fiecare țară are propria cultură."
    },
    {
      "text": "Îmi place să călătoresc în țări străine."
    },
    {
      "text": "Țara are multe peisaje diferite."
