  "data": {
    "headword": "nevinovat",
    "definition": "Care nu este vinovat de o faptă greșită sau infracțiune; lipsit de vină.",
    "pronunciation": "/neviˈno̯vat/",
    "etymology": {
      "text": "Adjectivul românesc „nevinovat” provine din latinescul 'innocentem' (în acuzativ 'innocentem', ulterior 'nevinovat'), format din 'in-' (nu) și 'nocere' (a face rău), însemnând 'nevinovat' sau 'fără vină'.",
      "source": "Dicționare etimologice, Analize lingvistice"
    }
  },
  "examples": [
    {
      "text": "Acuzatul a fost declarat nevinovat."
    },
    {
      "text": "Ea este nevinovată de accident."
    },
    {
      "text": "Nu ar trebui să acuzi pe nimeni nevinovat."
    },
    {
      "text": "Copilul pare atât de nevinovat."
    }
