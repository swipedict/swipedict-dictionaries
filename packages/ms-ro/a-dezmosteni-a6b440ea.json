  "data": {
    "headword": "a dezmoșteni",
    "definition": "A lua cuiva dreptul de a fi luat în considerare ca moștenitor.",
    "pronunciation": "/a dezmoʃˈteni/",
    "etymology": {
      "text": "Verbul românesc „a dezmoșteni” provine din latină, combinând prefixul 'dez-' (negare) cu 'moștenitor' (moștenitor), derivat din 'mos' (Vorfahre) și 'tenere' (ține).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "El și-a dezmoștenit fiul."
    },
    {
      "text": "Nu poți pur și simplu să dezmoștenești pe cineva."
    },
    {
      "text": "Părinții l-au dezmoștenit."
    },
    {
      "text": "A dezmoșteni înseamnă a lua dreptul la moștenire."
