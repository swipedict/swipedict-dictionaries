  "data": {
    "headword": "îngrășământ",
    "definition": "Substanță care adaugă nutrienți solului pentru a stimula creșterea plantelor.",
    "pronunciation": "/ɨnɡrəˈʃəmɨnt/",
    "etymology": {
      "text": "Cuvântul românesc „îngrășământ” derivă din verbul 'a îngrășa', împrumutat din italiană 'ingrassare', care înseamnă 'a îngrășa' sau 'a fertiliza'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Fermierul împrăștie îngrășământ pe câmp."
    },
    {
      "text": "Îngrășământul îmbunătățește calitatea solului."
    },
    {
      "text": "Îngrășământul organic este prietenos cu mediul."
    },
    {
      "text": "Plantele au nevoie de îngrășământ pentru o creștere sănătoasă."
    }
