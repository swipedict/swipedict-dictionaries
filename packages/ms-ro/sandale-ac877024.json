  "data": {
    "headword": "sandale",
    "definition": "Încălțăminte deschisă, formată din talpă și curele care fixează piciorul.",
    "pronunciation": "/sanˈda.le/",
    "etymology": {
      "text": "Cuvântul românesc „sandale” provine direct din latină 'sandalium', împrumutat din greaca veche 'sandalion', și desemnează încălțăminte deschisă.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "În vară port cu plăcere sandale."
    },
    {
      "text": "Aceste sandale sunt foarte comode."
    },
    {
      "text": "Sandalele se potrivesc bine cu o rochie ușoară."
    },
    {
      "text": "Am cumpărat sandale noi."
    }
