  "data": {
    "headword": "a respira profund",
    "definition": "a lua o respirație profundă sau a inspira și expira aerul adânc",
    "pronunciation": "/a res.piˈra proˈfund/",
    "etymology": {
      "text": "Expresia românească „a respira“ provine din latină, din „respirare“, care înseamnă „a respira“, iar „profund“ înseamnă „adânc“, deci „a respira profund“ înseamnă a lua o respirație adâncă.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
