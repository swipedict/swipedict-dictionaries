  "data": {
    "headword": "a afla",
    "definition": "a învăța sau a primi informații noi sau importante",
    "pronunciation": "/a afˈla/",
    "etymology": {
      "text": "Verbul românesc „a afla“ provine probabil din slavă și înseamnă „a afla, a recunoaște“; este folosit pentru a exprima dobândirea de cunoștințe sau informații.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Eu aflu știrea din prima mână."
    },
    {
      "text": "Aflai detalii luni?"
    },
    {
