  "data": {
    "headword": "poate",
    "definition": "Adverb care exprimă posibilitatea sau incertitudinea, echivalent cu 'eventual' sau 'posibil'.",
    "pronunciation": "/poˈa.te/",
    "etymology": {
      "text": "Cuvântul românesc „poate” derivă din verbul latin 'potere', care înseamnă „a putea”, evoluând spre exprimarea posibilității.",
      "source": "Dicționare etimologice românești"
    }
  },
  "examples": [
    {
      "text": "Poate vin mâine pe la tine."
    },
    {
      "text": "Poate plouă astăzi."
    },
    {
      "text": "El este poate deja acasă."
    },
    {
      "text": "Poate ai dreptate."
    }
