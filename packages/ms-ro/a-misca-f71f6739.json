  "data": {
    "headword": "a mișca",
    "definition": "a se deplasa de la un loc la altul; a pune în mișcare",
    "pronunciation": "/a miʃˈka/",
    "etymology": {
      "text": "Verbul românesc „a mișca“ provine din latină, din „movere“ (a mișca), însemnând a pune ceva în mișcare sau a se deplasa.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
