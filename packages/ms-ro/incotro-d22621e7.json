  "data": {
    "headword": "încotro",
    "definition": "Adverb interogativ, das nach dem Ziel oder der Richtung einer Bewegung fragt.",
    "pronunciation": "/ɨnˈkotro/",
    "etymology": {
      "text": "Cuvântul românesc „încotro” este format din prepoziția 'în' și pronumele demonstrativ 'cotro', care provine din latinescul 'contra', indicând direcția sau scopul unei mișcări.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Încotro mergi?"
    },
    {
      "text": "Spune-mi încotro să mergem."
    },
    {
      "text": "Încotro zboară pasărea?"
    },
    {
      "text": "Nu știu încotro să merg."
