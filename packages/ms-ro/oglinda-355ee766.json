    "etymology": {
      "text": "Cuvântul românesc „oglindă” derivă din latină 'oculus' (ochi), printr-o evoluție populară care a extins sensul la un obiect reflectorizant.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
