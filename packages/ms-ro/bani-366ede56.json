  "data": {
    "headword": "bani",
    "definition": "Mijloc de plată general acceptat sub formă de monede sau bancnote, folosit pentru cumpărarea de bunuri și servicii.",
    "pronunciation": "/ˈbani/",
    "etymology": {
      "text": "Cuvântul românesc „bani” provine din slavona veche 'banъ', care inițial desemna un titlu de conducător sau responsabil cu moneda, fiind ulterior asociat cu banii.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Nu am bani la mine."
    },
    {
      "text": "Banii sunt pe masă."
    },
    {
      "text": "El economisește bani pentru vacanță."
    },
    {
      "text": "Banii nu aduc fericirea."
