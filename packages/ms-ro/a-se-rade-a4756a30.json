  "data": {
    "headword": "a se rade",
    "definition": "A îndepărta părul de pe față sau alte părți ale corpului cu ajutorul unui aparat sau al unei lame de ras.",
    "pronunciation": "/a se ˈrade/",
    "etymology": {
      "text": "Verbul românesc „a se rade” provine din verbul latin 'radere', care înseamnă 'a răzui' sau 'a rade' și stă la baza multor cuvinte romanice cu sens similar.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Mă rad în fiecare dimineață."
    },
    {
      "text": "El nu s-a ras ieri."
    },
    {
      "text": "Rade-te cu grijă să nu te tai."
    },
    {
      "text": "Ne radem înainte de întâlnire."
    },
    {
      "text": "Ea își rade picioarele."
