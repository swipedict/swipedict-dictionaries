  "data": {
    "headword": "Pe curând",
    "definition": "O formă informală de rămas bun, care înseamnă 'până curând' oder 'ne vedem mai târziu'.",
    "pronunciation": "/pe kuˈrɨnd/",
    "etymology": {
      "text": "Cuvântul românesc 'curând' provine din latină, din 'curandus', care înseamnă 'de îngrijit', iar mai târziu a căpătat sensul de 'în curând'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Pe curând! Ne vedem mâine."
    },
    {
      "text": "Eu spun 'Pe curând' când plec."
    },
    {
      "text": "Pe curând, toate cele bune!"
    }
