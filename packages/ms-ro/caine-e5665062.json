  "data": {
    "headword": "câine",
    "definition": "Un mamifer domestic, de obicei patruped, ținut ca animal de companie și adesea folosit ca însoțitor al omului.",
    "pronunciation": "/kɨˈjne/",
    "etymology": {
      "text": "Cuvântul românesc „câine” provine din latinescul 'canis', care desemna în latină câinele și a dat naștere unor forme similare în multe limbi romanice.",
      "source": "Dicționare etimologice, studii lingvistice"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Câinele latră tare."
    },
    {
      "text": "Am un câine maro."
    },
    {
      "text": "Câinele aleargă în grădină."
    },
    {
      "text": "Câinele meu este foarte prietenos."
    }
