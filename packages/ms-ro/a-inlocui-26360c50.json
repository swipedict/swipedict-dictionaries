  "data": {
    "headword": "a înlocui",
    "definition": "a schimba ceva cu altceva sau a lua un loc",
    "pronunciation": "/ɨnloˈkui/",
    "etymology": {
      "text": "Verbul românesc „a înlocui“ derivă din latină, de la „locare“ („a pune, a așeza“) și prefixul „în-“ („înăuntru“), având sensul de „a pune în locul cuiva/ceva“.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
