  "data": {
    "headword": "opoziție",
    "definition": "Starea sau acțiunea de a se opune sau de a rezista cuiva sau ceva, în special în politică sau societate.",
    "pronunciation": "/opoˈzit͡sie/",
    "etymology": {
      "text": "Substantivul românesc „opoziție” provine direct din latină, de la 'oppositio', care înseamnă 'opusție' sau 'rezistență', preluat în limba română prin intermediul latină clasică.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Opoziția critică dur guvernul."
    },
    {
      "text": "Într-o democrație, opoziția joacă un rol important."
