  "data": {
    "headword": "lapte",
    "definition": "o substanță albă, lichidă, obținută din ugerul mamiferelor, folosită ca băutură sau în bucătărie",
    "pronunciation": "/ˈlaptɛ/",
    "etymology": {
      "text": "Cuvântul românesc „lapte“ provine din latină „lac“ și desemnează lichidul produs de mamifere pentru hrănire.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "neuter"
  },
  "examples": [
    {
      "text": "Îmi place să beau lapte cu cafea."
    },
    {
      "text": "Laptele provine de la vaci."
    },
    {
      "text": "El a cumpărat lapte proaspăt."
    },
    {
      "text": "Laptele este folosit pentru a produce brânză."
    },
    {
      "text": "Ea nu-i place produsele lactate."
    },
    {
      "text": "Laptele este o sursă importantă de hrană."
