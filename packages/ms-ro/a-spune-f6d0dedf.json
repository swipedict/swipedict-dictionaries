  "data": {
    "headword": "a spune",
    "definition": "A rosti cuvinte, a exprima sau a comunica ceva oral.",
    "pronunciation": "/a spuˈne/",
    "etymology": {
      "text": "Verbul românesc „a spune” provine din verbul latin 'spōnĕre', care înseamnă 'a plasa, a pune' și a evoluat semantic în română către sensul 'a spune, a comunica'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Îți spun adevărul."
    },
    {
      "text": "Ce ai spus?"
    },
    {
      "text": "El spune că vine mâine."
    },
    {
      "text": "Te rog, spune-mi unde locuiești."
    },
    {
      "text": "Adesea spunem ce gândim."
