  "data": {
    "headword": "vecin",
    "definition": "Persoană care locuiește în apropiere, de obicei în aceeași clădire sau pe aceeași stradă.",
    "pronunciation": "/veˈt͡ʃin/",
    "etymology": {
      "text": "Cuvântul românesc „vecin” provine din latină, din 'vicinus', care înseamnă 'aproape' sau 'vecin', având rădăcini în latina clasică.",
      "source": "Dicționare etimologice, studii lingvistice"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Vecinul meu este foarte prietenos."
    },
    {
      "text": "Vecinii au făcut o petrecere."
    },
    {
      "text": "Ieri m-am întâlnit cu vecinul meu."
    },
    {
      "text": "Vecinii noștri locuiesc în aceeași casă."
    }
