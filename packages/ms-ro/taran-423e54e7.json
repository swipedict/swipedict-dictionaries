  "data": {
    "headword": "țăran",
    "definition": "Persoană care se ocupă cu agricultura și creșterea animalelor.",
    "pronunciation": "/t͡səˈran/",
    "etymology": {
      "text": "Das rumänische Wort „țăran“ stammt vom lateinischen 'tārrānus' ab, was 'Bewohner des Landes, Bauer' bedeutete.",
      "source": "Dicționare etimologice românești"
    },
    "genus": "masculine"
  },
  "examples": [
    {
      "text": "Țăranul lucrează pe câmp."
    },
    {
      "text": "Mulți țărani trăiesc din agricultură."
    },
    {
      "text": "Țăranul are multe animale la ferma sa."
    },
    {
      "text": "În trecut, majoritatea oamenilor erau țărani."
    }
