  "data": {
    "headword": "briză",
    "definition": "Un vânt ușor și plăcut, adesea venit de la mare sau lac.",
    "pronunciation": "/briˈzə/",
    "etymology": {
      "text": "Cuvântul românesc „briză” este împrumutat din francezul 'brise', care desemnează un vânt ușor, provenind din vechiul francez 'briser'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "O briză plăcută bătea de la mare."
    },
    {
      "text": "În vară mă bucur de briza răcoroasă de pe plajă."
    },
    {
      "text": "Briza a răcit aerul fierbinte."
    },
    {
      "text": "Seara apare adesea o briză blândă."
    }
