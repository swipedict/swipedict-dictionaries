  "data": {
    "headword": "gară",
    "definition": "Un loc unde trenurile opresc pentru a permite pasagerilor să urce sau să coboare.",
    "pronunciation": "/ɡaˈrə/",
    "etymology": {
      "text": "Cuvântul românesc „gară“ provine din franceza „gare“, care înseamnă „stație de tren“ sau „oprire“, împrumutat din italiană „guardia“ (pază).",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "feminine"
  },
  "examples": [
    {
      "text": "Trenul sosește la gară."
    },
    {
      "text": "Te aștept la gară."
    },
    {
      "text": "Ceasul din gară arată ora exactă."
    },
    {
      "text": "La gară este un chioșc."
    }
