    "headword": "mândru",
    "definition": "o senzație pozitivă de satisfacție față de realizările proprii sau ale altora",
    "pronunciation": "/ˈmɨndru/",
    "etymology": {
      "text": "Cuvântul românesc „mândru“ provine din slavonul „mindre“, care înseamnă „mândru“ și este legat de sentimentul de satisfacție.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    },
    "genus": "masculine"
  },
