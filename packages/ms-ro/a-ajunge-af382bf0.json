  "data": {
    "headword": "a ajunge",
    "definition": "a merge la un anumit loc sau a atinge o anumită stare",
    "pronunciation": "/a aˈd͡ʒuŋʒe/",
    "etymology": {
      "text": "Verbul românesc „a ajunge“ provine din latină, din „adjungere“, care înseamnă „a adăuga“ sau „a conecta“, folosit pentru a exprima actul de a ajunge.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
