    "etymology": {
      "text": "Verbul românesc „a critica” provine direct din latinescul 'criticare', care la rândul său provine din grecescul 'kritikós', însemnând 'care judecă'.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
