  "data": {
    "headword": "a ninge",
    "definition": "A cădea fulgi de zăpadă din cer, a fi ninsoare.",
    "pronunciation": "/a ˈniŋɡe/",
    "etymology": {
      "text": "Verbul românesc „a ninge” provine din verbul latin 'ningere', care însemna 'a ninge' și s-a păstrat în limbile romanice.",
      "source": "Etymological Dictionaries, Linguistic Analysis"
    }
  },
  "examples": [
    {
      "text": "Ninge toată ziua astăzi."
    },
    {
      "text": "Ieri a nins puternic."
    },
    {
      "text": "Iarna ningea des."
    },
    {
      "text": "Mâine va ninge."
